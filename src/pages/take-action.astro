---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeading from '../components/content/SectionHeading.astro';
import NewsletterSignup from '../components/content/NewsletterSignup.astro';
import meetings from '../data/meetings.json';
import officials from '../data/officials.json';

// Split the roster into Mayor first, council members in the order the
// village publishes them, and any village staff (fiscal officer, etc.)
// at the end as a small auxiliary list.
const mayor = officials.find((o) => o.role === 'Mayor');
const council = officials.filter((o) => o.role === 'Council Member');
const staff = officials.filter(
  (o) => o.role !== 'Mayor' && o.role !== 'Council Member'
);

// Format a four-digit year from a YYYY-MM-DD string. Used for the
// term display on each official card.
const yearOf = (d: string | null) =>
  d ? new Date(`${d}T12:00:00`).getFullYear() : null;

const lastUpdated = '04.25 / 2026';

// Next meeting display.
const nextMeeting = meetings[0];
const nextMeetingDate = nextMeeting
  ? (() => {
      const d = new Date(`${nextMeeting.date}T12:00:00`);
      const mm = String(d.getMonth() + 1).padStart(2, '0');
      const dd = String(d.getDate()).padStart(2, '0');
      return `${mm}.${dd} / ${d.getFullYear()}`;
    })()
  : null;
---

<SiteLayout
  title="Take action | Help protect Foxfire"
  description="Sign up for updates, attend meetings, contact officials, volunteer, and help organize residents around the Foxfire-adjacent data-center issue."
  lastUpdated={lastUpdated}
>
  <!-- Hero strip (hero register) -->
  <section class="page-section page-section-tier hero hero-take-action">
    <div class="measure-wide">
      <p class="kicker">Take action</p>
      <h1 class="hero-display">This is not over. Help protect Foxfire.</h1>
      <p class="lede">
        Five concrete things a resident can do this week. Sign up for updates, attend the next
        meeting, email the council, volunteer for records review, or share with a neighbor.
      </p>
    </div>
  </section>

  <!-- Action 1: Sign up for updates. -->
  <section id="sign-up" class="page-section page-section-tight updates-section">
    <div class="measure">
      <p class="kicker">Action 01.</p>
      <h2 class="updates-title">Sign up for updates.</h2>
      <p class="updates-lede">
        A short note before every meeting on the data center issue, plus a recap after, plus
        an alert when a deadline is real. No spam, no other lists.
      </p>
      <NewsletterSignup />
    </div>
  </section>

  <!-- Action 2: Attend the next meeting. -->
  <section id="attend" class="page-section">
    <div class="measure">
      <SectionHeading kicker="Action 02." title="Attend the next meeting." />
      {nextMeeting && nextMeetingDate && (
        <div class="meeting-detail">
          <p class="meeting-detail-date mono tab">{nextMeetingDate}</p>
          <p class="meeting-detail-body">{nextMeeting.note}</p>
          <p class="action-foot">
            <a href={nextMeeting.source.url} rel="noopener" target="_blank">
              {nextMeeting.source.label} <span aria-hidden="true">→</span>
            </a>
          </p>
        </div>
      )}
      <p>
        Council and Committee of the Whole meetings are open to the public, are often
        livestreamed, and accept public comment. Showing up is the single most useful thing a
        neighbor can do.
      </p>
    </div>
  </section>

  <!-- Action 3: Email the council. Template ships inline with copy-to-clipboard. -->
  <section id="email" class="page-section">
    <div class="measure">
      <SectionHeading kicker="Action 03." title="Email the council." />
      <p>
        A polite, specific email becomes part of the public record and is read into the
        meeting. The template below is short on purpose. Edit it in your own voice before
        sending.
      </p>

      <div class="email-template" data-email-template>
        <div class="email-template-row">
          <div class="email-template-row-head">
            <p class="kicker email-template-label">Subject.</p>
            <button type="button" class="btn-tertiary email-template-copy" data-copy-target="email-template-subject">
              Copy subject.
            </button>
          </div>
          <pre class="email-template-text" id="email-template-subject">Please provide full transparency on the Foxfire-adjacent data-center project</pre>
        </div>

        <div class="email-template-row">
          <div class="email-template-row-head">
            <p class="kicker email-template-label">Body.</p>
            <button type="button" class="btn-tertiary email-template-copy" data-copy-target="email-template-body">
              Copy body.
            </button>
          </div>
          <pre class="email-template-text" id="email-template-body">I am a resident concerned about the Foxfire-adjacent data-center project. Please provide full transparency, complete records, independent review, and clear public answers about zoning, utilities, water, noise, traffic, environmental impacts, and next approvals.</pre>
        </div>

        <div class="email-template-recipients">
          <p class="kicker email-template-label">Send to.</p>
          <p class="email-template-fineprint">
            Roster verified against the Village of Commercial Point's elected officials page.
            Send to one official, several, or all of them. CC the others when you do, so the
            email becomes part of the public record across the council.
          </p>
        </div>
      </div>

      <!-- Council and Mayor roster. Sourced from the Village of Commercial
           Point's published elected officials page. Mayor Geiger's email
           is verified against village minutes. Each card shows term-end
           year in mono so residents can see who is up for re-election. -->
      <div class="officials-roster">
        {mayor && (
          <article class="official-card official-card-mayor">
            <p class="kicker official-role">{mayor.role}</p>
            <h3 class="official-name">{mayor.name}</h3>
            <a class="official-email mono" href={`mailto:${mayor.email}`}>{mayor.email}</a>
            {mayor.notes && <p class="official-notes">{mayor.notes}</p>}
          </article>
        )}
        <div class="officials-grid">
          {council.map((o) => {
            const startYear = yearOf(o.term_start);
            const endYear = yearOf(o.term_end);
            return (
              <article class="official-card">
                <p class="kicker official-role">{o.role}</p>
                <h3 class="official-name">{o.name}</h3>
                <a class="official-email mono" href={`mailto:${o.email}`}>{o.email}</a>
                {startYear && endYear && (
                  <p class="official-term mono tab">Term {startYear} to {endYear}</p>
                )}
                {o.notes && <p class="official-notes">{o.notes}</p>}
              </article>
            );
          })}
        </div>

        {staff.length > 0 && (
          <div class="officials-staff">
            <p class="kicker">Village staff</p>
            <ul>
              {staff.map((o) => (
                <li>
                  <span class="official-staff-role">{o.role}:</span>
                  <span class="official-staff-name">{o.name}.</span>
                  <a class="mono" href={`mailto:${o.email}`}>{o.email}</a>
                  {o.notes && <span class="official-staff-note"> {o.notes}</span>}
                </li>
              ))}
            </ul>
          </div>
        )}

        <p class="officials-foot">
          Roster sourced from the
          <a href="https://www.commercialpointohio.gov/council/" rel="noopener" target="_blank">
            Village of Commercial Point elected officials page <span aria-hidden="true">→</span>
          </a>
          . Village hall: <span class="mono tab">10 West Scioto St., Commercial Point, Ohio 43116</span>.
          Phone: <span class="mono tab">614-877-9248</span>.
        </p>
      </div>
    </div>
  </section>

  <script>
    // Copy-to-clipboard for the email template. Vanilla JS, no framework.
    // Falls back gracefully when navigator.clipboard is unavailable: the
    // user can still select and copy the text manually.
    (function () {
      const buttons = document.querySelectorAll<HTMLButtonElement>('[data-copy-target]');
      if (!buttons.length) return;

      buttons.forEach((btn) => {
        btn.addEventListener('click', async () => {
          const targetId = btn.dataset.copyTarget;
          if (!targetId) return;
          const target = document.getElementById(targetId);
          if (!target) return;

          const text = (target.textContent ?? '').trim();
          const original = btn.textContent ?? '';

          try {
            await navigator.clipboard.writeText(text);
            btn.textContent = 'Copied.';
          } catch (_err) {
            // Older browsers: select the text so the user can copy by hand.
            const range = document.createRange();
            range.selectNodeContents(target);
            const sel = window.getSelection();
            if (sel) {
              sel.removeAllRanges();
              sel.addRange(range);
            }
            btn.textContent = 'Selected. Press cmd-C.';
          }

          window.setTimeout(() => {
            btn.textContent = original;
          }, 1800);
        });
      });
    })();
  </script>

  <!-- Action 4: Help review documents. -->
  <section id="volunteer" class="page-section">
    <div class="measure">
      <SectionHeading kicker="Action 04." title="Help review documents." />
      <p>
        The coalition is requesting public records and reviewing them line by line. If you can
        read carefully and take notes, you can help. Choose the records research checkbox in
        the signup form above and we will be in touch when the next batch returns.
      </p>
      <p class="action-foot">
        <a href="#sign-up">Volunteer for records review <span aria-hidden="true">→</span></a>
      </p>
    </div>
  </section>

  <!-- Action 5: Share with neighbors. -->
  <section id="share" class="page-section">
    <div class="measure">
      <SectionHeading kicker="Action 05." title="Share with neighbors." />
      <p>
        Forward this site to a neighbor. Print a flyer for a yard sign or coffee shop. Bring
        the link to your homeowners association. The page that does the most work here is
        <a href="/timeline">the timeline</a>, because it lets a neighbor see the entire public
        record in five minutes.
      </p>
    </div>
  </section>

  <!-- Mission + transparency statements -->
  <section class="page-section">
    <div class="measure">
      <SectionHeading kicker="Mission" title="Why this site exists." />
      <p>
        Homes of Foxfire Coalition Against Data Centers is a resident-led effort to educate
        neighbors, gather public records, ask clear questions, and protect the future of our
        community.
      </p>
      <p>
        This is not over. We are organizing now to demand answers, review the process, and
        help protect Foxfire.
      </p>
    </div>
  </section>

</SiteLayout>
