---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeading from '../components/content/SectionHeading.astro';
import Icon from '../components/content/Icon.astro';
import meetings from '../data/meetings.json';

const lastUpdated = '04.29 / 2026';

const petitionUrl = 'https://www.change.org/p/prevent-the-construction-of-data-centers-in-commercial-point-and-scioto-township';
const donateUrl = 'https://www.gofundme.com/f/support-community-action-against-data-center';

// Next meeting for the side-by-side box. Pre-format calendar pieces.
const nextMeeting = meetings[0];
const nextMeetingDateObj = nextMeeting
  ? new Date(`${nextMeeting.date}T12:00:00`)
  : null;
const nextMeetingMonth = nextMeetingDateObj
  ? nextMeetingDateObj.toLocaleDateString('en-US', { month: 'short' }).toUpperCase()
  : null;
const nextMeetingDay = nextMeetingDateObj ? nextMeetingDateObj.getDate() : null;
const nextMeetingWeekday = nextMeetingDateObj
  ? nextMeetingDateObj.toLocaleDateString('en-US', { weekday: 'long' })
  : null;
const nextMeetingYear = nextMeetingDateObj ? nextMeetingDateObj.getFullYear() : null;
---

<SiteLayout
  title="Homes of Foxfire Coalition | Commercial Point, Ohio"
  description="A resident-led coalition in Commercial Point, Ohio organizing against a 267-acre data center development next to the Foxfire neighborhood. Read the public record and take action."
  lastUpdated={lastUpdated}
>
  <!-- Hero -->
  <section class="page-section page-section-tier hero hero-tall">
    <div class="measure-wide">
      <p class="kicker">Foxfire Community</p>
      <h1 class="hero-display"><span class="hero-line">Giant data centers.</span><span class="hero-line">Nearly 267 acres.</span><span class="hero-line hero-line-accent">Your new neighbor.</span></h1>
      <p class="lede">
        Nearly 267 acres near Foxfire have been rezoned for data-center use. We're a resident-led
        coalition working to uncover the facts, demand transparency, and protect the future of our
        neighborhood.
      </p>
      <div class="hero-cta">
        <a class="btn-primary" href="#act">Take action <Icon name="megaphone" size={14} /></a>
      </div>
    </div>

    <a class="hero-scroll" href="#act" aria-label="Scroll to take action">
      <span class="hero-scroll-label">Scroll</span>
      <span class="hero-scroll-line" aria-hidden="true"></span>
    </a>
  </section>

  <!-- Action panel: full-bleed navy. Email signup left, next-meeting box right. -->
  <section id="act" class="page-section action-panel-navy">
    <div class="action-panel-grid">
      <!-- Left: signup -->
      <div class="action-panel-col action-panel-signup">
        <p class="kicker action-panel-kicker">Take action</p>
        <h2 class="action-panel-title">Get updates from the coalition.</h2>
        <p class="action-panel-lede">
          Short notes about meetings, events, and progress on the data center issue. No spam, no
          other lists. Unsubscribe anytime.
        </p>

        <!-- Hidden iframe absorbs Google's redirect so the visitor stays on the page -->
        <iframe name="signup-sink" style="display:none;" aria-hidden="true"></iframe>

        <form
          class="action-signup-form"
          method="post"
          action="https://docs.google.com/forms/d/e/1FAIpQLSc-wEeEq8BJeHjESK-u7f76FomLjlnTdKrdZ85lC9VOzm8DRA/formResponse"
          target="signup-sink"
          id="signup-form"
        >
          <div class="action-signup-grid">
            <div class="action-signup-field">
              <label for="signup-first-name">First name.</label>
              <input
                type="text"
                id="signup-first-name"
                name="entry.562094467"
                required
                autocomplete="given-name"
              />
            </div>
            <div class="action-signup-field">
              <label for="signup-last-name">Last name.</label>
              <input
                type="text"
                id="signup-last-name"
                name="entry.241538344"
                required
                autocomplete="family-name"
              />
            </div>
          </div>
          <div class="action-signup-field">
            <label for="signup-email">Email.</label>
            <input
              type="email"
              id="signup-email"
              name="entry.2041379243"
              required
              autocomplete="email"
            />
          </div>
          <div class="action-signup-field">
            <label for="signup-address">Address <span class="action-signup-optional">(optional).</span></label>
            <input
              type="text"
              id="signup-address"
              name="entry.1816766210"
              autocomplete="street-address"
            />
          </div>
          <button type="submit" class="btn-primary action-signup-submit">
            <span>Sign me up</span>
            <Icon name="mail" size={18} />
          </button>

          <!-- Success message shown after submit -->
          <div class="action-signup-success" id="signup-success" aria-live="polite" style="display:none;">
            <Icon name="thumbs-up" size={20} />
            <p>Thank you for joining the fight. Watch for short notes on meetings, key documents, and how to make your voice heard.</p>
          </div>
        </form>

        <script>
          const form = document.getElementById('signup-form');
          const success = document.getElementById('signup-success');
          if (form && success) {
            form.addEventListener('submit', () => {
              setTimeout(() => {
                form.reset();
                success.style.display = 'block';
              }, 500);
            });
          }
        </script>

      </div>

      <!-- Right: next meeting -->
      <aside class="action-panel-col action-panel-meeting" aria-label="Next council meeting">
        <p class="kicker action-panel-kicker">Next council meeting</p>

        <div class="action-meeting-cal-row">
          <div class="cal-block" aria-hidden="true">
            <div class="cal-month">{nextMeetingMonth}</div>
            <div class="cal-day">{nextMeetingDay}</div>
          </div>
          <div class="action-meeting-cal-meta">
            <p class="action-meeting-weekday">{nextMeetingWeekday}</p>
            <p class="action-meeting-year mono tab">{nextMeetingYear}</p>
          </div>
        </div>
        <div class="action-meeting-flag">
          <span class="action-meeting-flag-tag">
            <Icon name="gavel" size={12} />
            On the agenda
          </span>
          <span class="action-meeting-flag-text">Third reading of the 18-month data center moratorium.</span>
        </div>
        <p class="action-meeting-body">
          A moratorium ordinance must be read at three separate Council meetings before it can be
          adopted. This is the third and final reading. If passed, it pauses any new data center
          construction in the village for 18 months while questions about water, power, noise, and
          tax incentives are answered.
        </p>
        <ul class="action-meeting-list">
          <li>
            <span class="action-meeting-icon"><Icon name="map-pin" size={16} ariaLabel="Where" /></span>
            Village offices, 67 W. Scioto St., Commercial Point.
          </li>
          <li>
            <span class="action-meeting-icon"><Icon name="clock" size={16} ariaLabel="Time" /></span>
            7:00 PM. Doors open earlier.
          </li>
          <li>
            <span class="action-meeting-icon"><Icon name="microphone" size={16} ariaLabel="Public comment" /></span>
            Sign in to speak. Five minutes per resident.
          </li>
        </ul>
        <p class="action-meeting-foot">
          <a class="action-panel-link" href={nextMeeting.source.url} target="_blank" rel="noopener">
            Village meeting calendar <span aria-hidden="true">&rarr;</span>
          </a>
        </p>
      </aside>
    </div>
  </section>

  <!-- Petition + Donate: full-bleed two-up cards -->
  <section class="action-cta-section action-cta-bleed">
    <div class="action-cta-grid">
      <article class="action-cta-card action-cta-petition">
        <div class="action-cta-inner">
          <p class="kicker action-cta-kicker">Petition</p>
          <h2 class="action-cta-title">
            <span class="action-cta-title-icon" aria-hidden="true"><Icon name="pen" size={28} /></span>
            Sign the petition.
          </h2>
          <p class="action-cta-body">
            Add your name to the coalition petition to prevent the construction of data centers
            in Commercial Point and Scioto Township. Every signature is part of the public record
            we bring to council.
          </p>
          <p class="action-cta-foot">
            <a class="btn-primary action-cta-btn" href={petitionUrl} target="_blank" rel="noopener">
              Sign the petition <Icon name="pen" size={14} />
            </a>
          </p>
        </div>
      </article>
      <article class="action-cta-card action-cta-donate">
        <div class="action-cta-inner">
          <p class="kicker action-cta-kicker">Donate</p>
          <h2 class="action-cta-title">
            <span class="action-cta-title-icon" aria-hidden="true"><Icon name="heart" size={28} /></span>
            Make a donation.
          </h2>
          <p class="action-cta-body">
            Support the coalition through GoFundMe. Donations help fund legal research, public
            records requests, expert reviews, printing, and outreach to neighbors who have not
            heard yet. <strong>Every dollar is tracked and publicly recorded.</strong>
          </p>
          <p class="action-cta-foot">
            <a class="btn-secondary action-cta-btn" href={donateUrl} target="_blank" rel="noopener">
              Make a donation <Icon name="heart" size={14} />
            </a>
          </p>
        </div>
      </article>
    </div>
  </section>

  <!-- What happened -->
  <section id="story" class="page-section story-section">
    <div class="story-layout">

      <!-- Left: text + status table + CTA -->
      <div class="story-content">
        <SectionHeading
          kicker="What happened"
          title="A massive data-center project is being planned near Foxfire. Residents deserve answers."
        />
        <p>
          In May 2024, the Village of Commercial Point approved Ordinance 2024-07, rezoning nearly
          267 acres of the K-Nova / Jahn Farm property near Foxfire to Planned Industrial District
          with development standards permitting only data centers.
        </p>
        <p>
          Since then, additional records and meeting minutes have raised important questions about
          the project timeline, emergency passage of the ordinance, public notice, utility impacts,
          and the role of K-Nova, Amazon Web Services, and our own Council.
        </p>
        <p>
          This site exists to help residents understand the public record, follow what happens
          next, and take action together.
        </p>

        <p class="section-foot">
          <a href="/timeline">Read the full timeline <span aria-hidden="true">&rarr;</span></a>
        </p>
      </div>

      <!-- Right: entrance sign photo, offset -->
      <div class="story-image-col" aria-hidden="true">
        <figure class="story-image-frame">
          <img
            src="/1c5afbb224f8de316a605d2ad10e7550-cc_ft_768.webp"
            alt="Foxfire & The Players Club entrance sign, Commercial Point, Ohio"
            width="600"
            height="750"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>

    </div>
  </section>

  <!-- Pre-footer: Foxfire neighborhood aerial -->
  <section class="pre-footer" aria-label="Foxfire neighborhood">
    <div class="pre-footer-inner">
      <p class="pre-footer-kicker">The neighborhood</p>
      <h2 class="pre-footer-title">
        Our neighborhood.<br />Our families.<br />Our future here.
      </h2>
      <p class="pre-footer-body">
        Foxfire is where hundreds of families have made homes and raised kids. The coalition is
        organizing to keep it that way. We are putting the public record in one place so the
        people who live here have a real say in what comes next.
      </p>
      <p class="pre-footer-ctas">
        <a class="btn-primary" href="/take-action">Help protect Foxfire <Icon name="megaphone" size={14} /></a>
      </p>
    </div>
  </section>
</SiteLayout>
