---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeading from '../components/content/SectionHeading.astro';
import Icon from '../components/content/Icon.astro';
import meetings from '../data/meetings.json';
import { updates, cardThumbnail } from '../data/updates';
import { sanity, QUERY_HOME_PAGE, type SanityHomePage } from '../lib/sanity';
import { toHTML } from '@portabletext/to-html';

const lastUpdated = '04.30 / 2026';

// Fetch homepage content from Sanity. Falls back to hardcoded defaults if the document
// is missing or any individual field is empty. Lets the site keep rendering even when
// the Studio is empty.
let home: SanityHomePage = {};
try {
  home = (await sanity.fetch<SanityHomePage | null>(QUERY_HOME_PAGE)) || {};
} catch (err) {
  console.warn('[index.astro] Sanity fetch failed:', err);
}

// Hero
const heroKicker = home.heroKicker || 'Foxfire Community';
const heroLine1 = home.heroLine1 || 'Giant data centers.';
const heroLine2 = home.heroLine2 || 'Nearly 267 acres.';
const heroLine3 = home.heroLine3 || 'Your new neighbor.';
const heroLede = home.heroLede || `Nearly 267 acres near Foxfire have been rezoned for data-center use. We're a resident-led coalition working to uncover the facts, demand transparency, and protect the future of our neighborhood.`;
const heroCtaLabel = home.heroCtaLabel || 'Take action';

// Signup
const signupKicker = home.signupKicker || 'Take action';
const signupTitle = home.signupTitle || 'Get updates from the coalition.';
const signupLede = home.signupLede || 'Short notes about meetings, events, and progress on the data center issue. No spam, no other lists. Unsubscribe anytime.';
const signupSuccessMessage = home.signupSuccessMessage || 'Thank you for joining the fight. Watch for short notes on meetings, key documents, and how to make your voice heard.';

// Meeting
const meetingKicker = home.meetingKicker || 'Next council meeting';
const meetingAgendaTag = home.meetingAgendaTag || 'On the agenda';
const meetingAgendaText = home.meetingAgendaText || 'Third reading of the 18-month data center moratorium.';
const meetingBody = home.meetingBody || 'A moratorium ordinance must be read at three separate Council meetings before it can be adopted. This is the third and final reading. If passed, it pauses any new data center construction in the village for 18 months while questions about water, power, noise, and tax incentives are answered.';
const meetingAddress = home.meetingAddress || 'Village offices, 10 W. Scioto St., Commercial Point.';
const meetingMapsUrl = 'https://www.google.com/maps/search/?api=1&query=10%20W%20Scioto%20St%2C%20Commercial%20Point%2C%20OH%2043116';
const meetingTime = home.meetingTime || '7:00 PM. Doors open earlier.';
const meetingPublicComment = home.meetingPublicComment || 'Sign in to speak. Five minutes per resident.';

// Petition / Donate
const petitionKicker = home.petitionKicker || 'Petition';
const petitionTitle = home.petitionTitle || 'Sign the petition.';
const petitionBody = home.petitionBody || 'Add your name to the coalition petition to prevent the construction of data centers in Commercial Point and Scioto Township. Every signature is part of the public record we bring to council.';
const petitionCtaLabel = home.petitionCtaLabel || 'Sign the petition';
const petitionUrl = home.petitionUrl || 'https://www.change.org/p/prevent-the-construction-of-data-centers-in-commercial-point-and-scioto-township';

const donateKicker = home.donateKicker || 'Donate';
const donateTitle = home.donateTitle || 'Make a donation.';
const donateBodyHtml = (home.donateBody && Array.isArray(home.donateBody) && home.donateBody.length > 0)
  ? toHTML(home.donateBody as any)
  : `<p>Support the coalition through GoFundMe. Donations help fund legal research, public records requests, expert reviews, printing, and outreach to neighbors who have not heard yet. <strong>Every dollar is tracked and publicly recorded.</strong></p>`;
const donateCtaLabel = home.donateCtaLabel || 'Make a donation';
const donateUrl = home.donateUrl || 'https://www.gofundme.com/f/support-community-action-against-data-center';

// Story
const storyKicker = home.storyKicker || 'What happened';
const storyTitle = home.storyTitle || 'A massive data-center project is being planned near Foxfire. Residents deserve answers.';
const storyBodyHtml = (home.storyBody && Array.isArray(home.storyBody) && home.storyBody.length > 0)
  ? toHTML(home.storyBody as any)
  : `<p>In May 2024, the Village of Commercial Point approved <a href="https://www.commercialpointohio.gov/CPDocuments/CPOrdinances/2024/2024-07.pdf" target="_blank" rel="noopener">Ordinance 2024-07</a>, rezoning nearly 267 acres of the K-Nova / Jahn Farm property near Foxfire to Planned Industrial District with development standards permitting only data centers.</p>
<p>Since then, additional records and meeting minutes have raised important questions about the project timeline, emergency passage of the ordinance, public notice, utility impacts, and the role of K-Nova, Amazon Web Services, and our own Council.</p>
<p>This site exists to help residents understand the public record, follow what happens next, and take action together.</p>`;
const storyTimelineLinkLabel = home.storyTimelineLinkLabel || 'Read the full timeline';

// Pre-footer
const preFooterKicker = home.preFooterKicker || 'The neighborhood';
const preFooterTitleLine1 = home.preFooterTitleLine1 || 'Our neighborhood.';
const preFooterTitleLine2 = home.preFooterTitleLine2 || 'Our families.';
const preFooterTitleLine3 = home.preFooterTitleLine3 || 'Our future here.';
const preFooterBody = home.preFooterBody || 'Foxfire is where hundreds of families have made homes and raised kids. The coalition is organizing to keep it that way. We are putting the public record in one place so the people who live here have a real say in what comes next.';
const preFooterCtaLabel = home.preFooterCtaLabel || 'Help protect Foxfire';
const preFooterCtaUrl = home.preFooterCtaUrl || '/take-action';

// Latest updates for homepage section.
const publishedUpdates = [...updates]
  .filter((u) => !u.draft)
  .sort((a, b) => b.publishDate.localeCompare(a.publishDate));

// If any post is explicitly featured, use it; otherwise fall back to most recent.
const featuredUpdate = publishedUpdates.find((u) => u.featured) ?? publishedUpdates[0] ?? null;
// Recent list: up to 3 posts, excluding the featured one.
const recentUpdates = publishedUpdates.filter((u) => u !== featuredUpdate).slice(0, 3);

// Next meeting for the side-by-side box. Pre-format calendar pieces.
const nextMeeting = meetings[0];
const nextMeetingDateObj = nextMeeting
  ? new Date(`${nextMeeting.date}T12:00:00`)
  : null;
const nextMeetingMonth = nextMeetingDateObj
  ? nextMeetingDateObj.toLocaleDateString('en-US', { month: 'short' }).toUpperCase()
  : null;
const nextMeetingDay = nextMeetingDateObj ? nextMeetingDateObj.getDate() : null;
const nextMeetingWeekday = nextMeetingDateObj
  ? nextMeetingDateObj.toLocaleDateString('en-US', { weekday: 'long' })
  : null;
const nextMeetingYear = nextMeetingDateObj ? nextMeetingDateObj.getFullYear() : null;
---

<SiteLayout
  title="Homes of Foxfire Coalition | Commercial Point, Ohio"
  description="A resident-led coalition in Commercial Point, Ohio organizing against a 267-acre data center development next to the Foxfire neighborhood. Read the public record and take action."
  lastUpdated={lastUpdated}
>
  <!-- Hero -->
  <section class="page-section page-section-tier hero hero-tall">
    <div class="measure-wide">
      <p class="kicker">{heroKicker}</p>
      <h1 class="hero-display"><span class="hero-line">{heroLine1}</span><span class="hero-line">{heroLine2}</span><span class="hero-line hero-line-accent">{heroLine3}</span></h1>
      <p class="lede">{heroLede}</p>
      <div class="hero-cta">
        <a class="btn-primary" href="#act">{heroCtaLabel} <Icon name="megaphone" size={14} /></a>
        <a class="btn-hero-secondary" href="/questions">See our questions <Icon name="arrow-right" size={14} /></a>
      </div>
    </div>

    <a class="hero-scroll" href="#act" aria-label="Scroll to take action">
      <span class="hero-scroll-label">Scroll</span>
      <span class="hero-scroll-line" aria-hidden="true"></span>
    </a>
  </section>

  <!-- Action panel: full-bleed navy. Email signup left, next-meeting box right. -->
  <section id="act" class="page-section action-panel-navy">
    <div class="action-panel-grid">
      <!-- Left: signup -->
      <div class="action-panel-col action-panel-signup">
        <p class="kicker action-panel-kicker">{signupKicker}</p>
        <h2 class="action-panel-title">{signupTitle}</h2>
        <p class="action-panel-lede">{signupLede}</p>

        <!-- Hidden iframe absorbs Google's redirect so the visitor stays on the page -->
        <iframe name="signup-sink" style="display:none;" aria-hidden="true"></iframe>

        <form
          class="action-signup-form"
          method="post"
          action="https://docs.google.com/forms/d/e/1FAIpQLSc-wEeEq8BJeHjESK-u7f76FomLjlnTdKrdZ85lC9VOzm8DRA/formResponse"
          target="signup-sink"
          id="signup-form"
        >
          <div class="action-signup-grid">
            <div class="action-signup-field">
              <label for="signup-first-name">First name.</label>
              <input
                type="text"
                id="signup-first-name"
                name="entry.562094467"
                required
                autocomplete="given-name"
              />
            </div>
            <div class="action-signup-field">
              <label for="signup-last-name">Last name.</label>
              <input
                type="text"
                id="signup-last-name"
                name="entry.241538344"
                required
                autocomplete="family-name"
              />
            </div>
          </div>
          <div class="action-signup-field">
            <label for="signup-email">Email.</label>
            <input
              type="email"
              id="signup-email"
              name="entry.2041379243"
              required
              autocomplete="email"
            />
          </div>
          <div class="action-signup-field">
            <label for="signup-address">Address <span class="action-signup-optional">(optional).</span></label>
            <input
              type="text"
              id="signup-address"
              name="entry.1816766210"
              autocomplete="street-address"
            />
          </div>
          <button type="submit" class="btn-primary action-signup-submit">
            <span>Sign me up</span>
            <Icon name="mail" size={18} />
          </button>

          <!-- Success message shown after submit -->
          <div class="action-signup-success" id="signup-success" aria-live="polite" style="display:none;">
            <Icon name="thumbs-up" size={20} />
            <p>{signupSuccessMessage}</p>
          </div>
        </form>

        <script>
          // Signup form: dedupe-aware submit handling.
          //
          // - Wired on astro:page-load (initial + view transitions) instead of
          //   running once on DOMContentLoaded. Without this, returning to the
          //   homepage via view transitions leaves the form with no listener,
          //   the user thinks the submit didn't work, and re-submits → duplicate.
          // - Idempotent via data-wired so multiple page-loads don't double-bind.
          // - sessionStorage flag (shared with the /take-action form) blocks
          //   in-session double-submits across both pages and view transitions.
          // - In-memory `submitting` flag blocks rapid double-clicks before the
          //   storage flag is written.
          const SIGNUP_STORAGE_KEY = 'foxfire-signup-submitted';

          function initHomeSignupForm() {
            const form = document.getElementById('signup-form') as HTMLFormElement | null;
            const success = document.getElementById('signup-success') as HTMLElement | null;
            if (!form || !success) return;
            if (form.dataset.wired === 'true') return;
            form.dataset.wired = 'true';

            const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
            if (!submitBtn) return;

            const showSuccess = () => {
              form.style.display = 'none';
              success.style.display = 'flex';
            };

            // Already submitted this session (on this page or /take-action).
            if (sessionStorage.getItem(SIGNUP_STORAGE_KEY) === 'true') {
              showSuccess();
              return;
            }

            let submitting = false;
            form.addEventListener('submit', (e) => {
              if (submitting || sessionStorage.getItem(SIGNUP_STORAGE_KEY) === 'true') {
                e.preventDefault();
                return;
              }
              submitting = true;
              submitBtn.disabled = true;
              submitBtn.textContent = 'Sending…';
              sessionStorage.setItem(SIGNUP_STORAGE_KEY, 'true');
              setTimeout(showSuccess, 500);
            });
          }

          document.addEventListener('astro:page-load', initHomeSignupForm);
          if (document.readyState !== 'loading') {
            initHomeSignupForm();
          } else {
            document.addEventListener('DOMContentLoaded', initHomeSignupForm);
          }
        </script>

      </div>

      <!-- Right: next meeting -->
      <aside class="action-panel-col action-panel-meeting" aria-label="Next council meeting">
        <p class="kicker action-panel-kicker">{meetingKicker}</p>

        <div class="action-meeting-cal-row">
          <div class="cal-block" aria-hidden="true">
            <div class="cal-month">{nextMeetingMonth}</div>
            <div class="cal-day">{nextMeetingDay}</div>
          </div>
          <div class="action-meeting-cal-meta">
            <p class="action-meeting-weekday">{nextMeetingWeekday}</p>
            <p class="action-meeting-year mono tab">{nextMeetingYear}</p>
          </div>
        </div>
        <div class="action-meeting-flag">
          <span class="action-meeting-flag-tag">
            <Icon name="gavel" size={12} />
            {meetingAgendaTag}
          </span>
          <span class="action-meeting-flag-text">{meetingAgendaText}</span>
        </div>
        <p class="action-meeting-body">{meetingBody}</p>
        <ul class="action-meeting-list">
          <li>
            <span class="action-meeting-icon"><Icon name="map-pin" size={16} ariaLabel="Where" /></span>
            <a class="address-link" href={meetingMapsUrl} target="_blank" rel="noopener">{meetingAddress}</a>
          </li>
          <li>
            <span class="action-meeting-icon"><Icon name="clock" size={16} ariaLabel="Time" /></span>
            {meetingTime}
          </li>
          <li>
            <span class="action-meeting-icon"><Icon name="microphone" size={16} ariaLabel="Public comment" /></span>
            {meetingPublicComment}
          </li>
        </ul>
        <p class="action-meeting-foot">
          <a class="action-panel-link" href={nextMeeting.source.url} target="_blank" rel="noopener">
            Village meeting calendar <span aria-hidden="true">&rarr;</span>
          </a>
        </p>
      </aside>
    </div>
  </section>

  <!-- Petition + Donate: full-bleed two-up cards -->
  <section class="action-cta-section action-cta-bleed">
    <div class="action-cta-grid">
      <article class="action-cta-card action-cta-petition">
        <div class="action-cta-inner">
          <p class="kicker action-cta-kicker">{petitionKicker}</p>
          <h2 class="action-cta-title">
            <span class="action-cta-title-icon" aria-hidden="true"><Icon name="pen" size={28} /></span>
            {petitionTitle}
          </h2>
          <p class="action-cta-body">{petitionBody}</p>
          <p class="action-cta-foot">
            <a class="btn-primary action-cta-btn" href={petitionUrl} target="_blank" rel="noopener">
              {petitionCtaLabel} <Icon name="pen" size={14} />
            </a>
          </p>
        </div>
      </article>
      <article class="action-cta-card action-cta-donate">
        <div class="action-cta-inner">
          <p class="kicker action-cta-kicker">{donateKicker}</p>
          <h2 class="action-cta-title">
            <span class="action-cta-title-icon" aria-hidden="true"><Icon name="heart" size={28} /></span>
            {donateTitle}
          </h2>
          <div class="action-cta-body" set:html={donateBodyHtml}></div>
          <p class="action-cta-foot">
            <a class="btn-secondary action-cta-btn" href={donateUrl} target="_blank" rel="noopener">
              {donateCtaLabel} <Icon name="heart" size={14} />
            </a>
          </p>
        </div>
      </article>
    </div>
  </section>

  <!-- What happened -->
  <section id="story" class="page-section story-section">
    <div class="story-layout">

      <!-- Left: text + status table + CTA -->
      <div class="story-content">
        <SectionHeading
          kicker={storyKicker}
          title={storyTitle}
        />
        <div set:html={storyBodyHtml}></div>

        <div class="section-foot story-foot">
          <a class="story-timeline-link" href="/timeline">Read the full timeline</a>
          <button
            class="btn-plan"
            type="button"
            data-open-lightbox="plan"
            aria-haspopup="dialog"
          >
            <Icon name="file-text" size={14} />
            View the proposed plan
          </button>
        </div>
      </div>

      <!-- Right: entrance sign photo, offset -->
      <div class="story-image-col" aria-hidden="true">
        <figure class="story-image-frame">
          <img
            src="/1c5afbb224f8de316a605d2ad10e7550-cc_ft_768.webp"
            alt="Foxfire & The Players Club entrance sign, Commercial Point, Ohio"
            width="600"
            height="750"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>

    </div>
  </section>

  <!-- Latest updates -->
  {publishedUpdates.length > 0 && (
    <section class="page-section home-updates-section" aria-label="Latest coalition updates">
      <div class="measure-wide">

        <!-- Section header -->
        <div class="home-updates-head">
          <p class="kicker home-updates-kicker">Latest updates</p>
          <a class="home-updates-all" href="/updates">
            All updates <Icon name="arrow-right" size={12} />
          </a>
        </div>

        {/* Featured post — prominent callout */}
        {featuredUpdate && (
          <a class="home-featured-post" href={`/updates/${featuredUpdate.id}`} aria-label={featuredUpdate.title}>
            {cardThumbnail(featuredUpdate) && (
              <div class="home-featured-media">
                <img
                  src={cardThumbnail(featuredUpdate)!}
                  alt=""
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )}
            <div class="home-featured-body">
              <span class="home-featured-flag">
                <Icon name="arrow-right" size={10} />
                Featured update
              </span>
              <p class="home-featured-meta">
                <span class="mono tab">{featuredUpdate.publishDateLabel}</span>
                <span class="home-updates-dot" aria-hidden="true">·</span>
                <span>{featuredUpdate.category}</span>
              </p>
              <h2 class="home-featured-title">{featuredUpdate.title}</h2>
              <p class="home-featured-excerpt">{featuredUpdate.excerpt}</p>
              <span class="home-featured-cta">
                Read more <Icon name="arrow-right" size={12} />
              </span>
            </div>
          </a>
        )}

        {/* Recent list */}
        {recentUpdates.length > 0 && (
          <ul class="home-recent-list">
            {recentUpdates.map((u) => {
              const thumb = cardThumbnail(u);
              return (
                <li class="home-recent-item">
                  <a class="home-recent-link" href={`/updates/${u.id}`}>
                    {thumb && (
                      <div class="home-recent-media">
                        <img src={thumb} alt="" loading="lazy" decoding="async" />
                      </div>
                    )}
                    <div class="home-recent-body">
                      <p class="home-recent-meta">
                        <span class="mono tab">{u.publishDateLabel}</span>
                        <span class="home-updates-dot" aria-hidden="true">·</span>
                        <span>{u.category}</span>
                      </p>
                      <h3 class="home-recent-title">{u.title}</h3>
                      <p class="home-recent-excerpt">{u.excerpt}</p>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        )}

      </div>
    </section>
  )}

  <!-- Pre-footer: Foxfire neighborhood aerial -->
  <section class="pre-footer" aria-label="Foxfire neighborhood">
    <div class="pre-footer-inner">
      <p class="pre-footer-kicker">{preFooterKicker}</p>
      <h2 class="pre-footer-title">
        {preFooterTitleLine1}<br />{preFooterTitleLine2}<br />{preFooterTitleLine3}
      </h2>
      <p class="pre-footer-body">{preFooterBody}</p>
      <p class="pre-footer-ctas">
        <a class="btn-primary" href={preFooterCtaUrl}>{preFooterCtaLabel} <Icon name="megaphone" size={14} /></a>
      </p>
    </div>
  </section>

  <style>
    /* ── Latest updates section ──────────────────────────────────────────── */

    .home-updates-section {
      border-top: 1px solid var(--rule-soft);
    }

    /* Header row: kicker left, all-link right */
    .home-updates-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-md);
      margin-bottom: var(--space-xl);
    }

    .home-updates-kicker {
      margin: 0;
    }

    .home-updates-all {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-soft);
      text-decoration: none;
      transition: color 0.15s ease;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .home-updates-all:hover,
    .home-updates-all:focus-visible {
      color: var(--accent);
    }

    .home-updates-all :global(svg) {
      color: var(--accent);
    }

    .home-updates-dot {
      color: var(--rule-soft);
    }

    /* ── Featured post ──────────────────────────────────────────────────── */

    .home-featured-post {
      display: grid;
      grid-template-columns: minmax(300px, 440px) 1fr;
      gap: var(--space-2xl);
      align-items: center;
      text-decoration: none;
      color: inherit;
      background: var(--bone);
      margin-bottom: var(--space-2xl);
      transition: background 0.2s ease;
    }

    .home-featured-post:hover,
    .home-featured-post:focus-visible {
      background: var(--bone);
    }

    .home-featured-media {
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background: var(--ink);
    }

    .home-featured-media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.4s ease;
    }

    .home-featured-post:hover .home-featured-media img,
    .home-featured-post:focus-visible .home-featured-media img {
      transform: scale(1.025);
    }

    .home-featured-body {
      padding: var(--space-xl) var(--space-xl) var(--space-xl) 0;
      min-width: 0;
    }

    /* "Featured update" pill */
    .home-featured-flag {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-family: var(--mono);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--paper);
      background: var(--accent);
      padding: 3px 8px;
      margin-bottom: var(--space-md);
    }

    .home-featured-flag :global(svg) {
      color: currentColor;
      flex-shrink: 0;
    }

    .home-featured-meta {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-soft);
      margin: 0 0 var(--space-sm);
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-sm);
      align-items: baseline;
    }

    .home-featured-title {
      font-family: var(--headline);
      font-size: clamp(1.375rem, 2.2vw, 1.875rem);
      line-height: 1.2;
      font-weight: 500;
      color: var(--ink);
      margin: 0 0 var(--space-sm);
      text-wrap: balance;
      transition: color 0.15s ease;
    }

    .home-featured-post:hover .home-featured-title,
    .home-featured-post:focus-visible .home-featured-title {
      color: var(--accent);
    }

    .home-featured-excerpt {
      font-size: 15px;
      line-height: 1.55;
      color: var(--text);
      margin: 0 0 var(--space-md);
      max-width: 58ch;
    }

    .home-featured-cta {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-family: var(--body);
      font-size: 13px;
      font-weight: 500;
      color: var(--accent);
      border-bottom: 1px solid currentColor;
      padding-bottom: 1px;
    }

    .home-featured-cta :global(svg) {
      color: currentColor;
    }

    /* ── Recent list ───────────────────────────────────────────────────── */

    .home-recent-list {
      list-style: none;
      padding: 0;
