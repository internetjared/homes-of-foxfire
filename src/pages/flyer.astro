---
import BaseLayout from '../layouts/BaseLayout.astro';

const flyer = {
  documentId: 'FXF-FLYER-2026-001',
  version: 'v1.0',
  lastUpdated: '04.25.2026',
  hearing: {
    weekday: 'Wed',
    date: 'May 13, 2026',
    time: '7:00 PM',
    signIn: '6:45 PM',
    body: 'Village of Commercial Point Council',
    address: '5048 Cemetery Rd.',
  },
};
---
<BaseLayout title="Public hearing on Ordinance 2025-23 · Homes of Foxfire Coalition">
  <main class="stage" aria-label="Flyer preview">
    <article class="flyer" role="document">

      <header class="flyer-head">
        <div class="kicker">
          {flyer.documentId} · Coalition Against Data Centers · Public notice
        </div>
        <div class="cover-rule" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
      </header>

      <h1 class="flyer-title">
        Public hearing on<br />Ordinance 2025-23.
      </h1>
      <p class="flyer-lede">
        Second reading. Resident comment period opens at 7:00 PM.
      </p>

      <aside class="hearing-card" role="note" aria-labelledby="hearing-card-label">
        <div class="hearing-stamp" id="hearing-card-label">Hearing notice</div>
        <div class="hearing-grid">
          <div class="hearing-when">
            <strong>{flyer.hearing.weekday} · {flyer.hearing.date}</strong>
            <span class="time">{flyer.hearing.time}</span>
            <span class="sub">Sign-in opens at {flyer.hearing.signIn}</span>
          </div>
          <div class="hearing-where">
            <span class="label">Where</span>
            <span class="body">{flyer.hearing.body}</span>
            <span class="addr">{flyer.hearing.address}</span>
          </div>
        </div>
      </aside>

      <section class="block">
        <div class="kicker">What is being proposed</div>
        <p class="copy">
          The K-Nova application rezones 266.971 acres along the Foxfire
          neighborhood and adjacent parcels in Commercial Point, Ohio, from
          Agricultural-Residential to Planned Industrial District. The
          applicant intends to build a data center campus on the parcels.
          Ordinance 2025-23 carries that rezone request.
        </p>
        <div class="figs mono tab">
          <span><b>266.971</b> acres</span>
          <span><b>1,250,000</b> gallons projected daily water draw</span>
          <span><b>ORD 2025-23</b></span>
        </div>
      </section>

      <section class="block">
        <div class="kicker">What you can do</div>
        <ul class="actions">
          <li>Attend the second reading and resident comment period.</li>
          <li>Read the ordinance and the planning commission packet.</li>
          <li>File a public records request under Ohio Rev. Code §149.43.</li>
          <li>Subscribe to coalition hearing alerts.</li>
        </ul>
      </section>

      <footer class="flyer-foot">
        <div class="wordmark">
          <div class="wm-rule" aria-hidden="true"></div>
          <div class="wm-primary">Homes of Foxfire</div>
          <div class="wm-secondary">Coalition Against Data Centers</div>
          <div class="wm-rule" aria-hidden="true"></div>
        </div>
        <div class="stamp-line">
          <span>foxfirecoalition.org</span>
          <span>{flyer.documentId} · {flyer.version}</span>
          <span>Last updated · {flyer.lastUpdated}</span>
        </div>
      </footer>

    </article>
  </main>
</BaseLayout>

<style>
  /* Stage — only visible on screen. Centers the letter-size sheet on a
     darker surface so the flyer reads as a printed page in preview. */
  .stage {
    min-height: 100vh;
    padding: 32px 16px;
    background: var(--bone);
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .flyer {
    width: 8.5in;
    min-height: 11in;
    padding: 0.75in;
    background: var(--paper);
    color: var(--text);
    box-shadow: 0 1px 2px rgba(0,0,0,0.06), 0 12px 40px rgba(0,0,0,0.12);
    display: flex;
    flex-direction: column;
    gap: 0.32in;
  }

  /* Top stamp */
  .flyer-head { display: flex; flex-direction: column; gap: 12px; }

  .cover-rule { display: flex; gap: 4px; }
  .cover-rule span { height: 5px; flex: 1; background: var(--ink); }
  .cover-rule span:nth-child(2) { background: var(--accent); flex: 0.4; }
  .cover-rule span:nth-child(3) { background: var(--bone-2); flex: 0.2; }

  /* Title and lede */
  .flyer-title {
    font-family: var(--headline);
    font-size: 56px;
    line-height: 1.04;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.01em;
    font-weight: 500;
    text-wrap: balance;
  }
  .flyer-lede {
    font-size: 18px;
    line-height: 1.5;
    color: var(--text-soft);
    margin: 0;
    max-width: none;
  }

  /* Hearing card — uses the brand's alert color, but only here.
     This is the single sanctioned use of Hearing Red on the flyer. */
  .hearing-card {
    border: 1px solid var(--alert);
    border-left-width: 3px;
    background: #FBEEEA;
    padding: 22px 26px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .hearing-stamp {
    align-self: flex-start;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--alert);
    border: 1px solid var(--alert);
    padding: 5px 10px;
  }
  .hearing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }
  .hearing-when strong {
    display: block;
    font-family: var(--headline);
    font-size: 28px;
    line-height: 1.1;
    color: var(--alert);
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .hearing-when .time {
    display: block;
    font-family: var(--headline);
    font-size: 22px;
    color: var(--alert);
    font-weight: 500;
    margin-top: 4px;
  }
  .hearing-when .sub {
    display: block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-soft);
    margin-top: 8px;
  }
  .hearing-where { display: flex; flex-direction: column; gap: 4px; }
  .hearing-where .label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-mute);
  }
  .hearing-where .body {
    font-family: var(--headline);
    font-size: 17px;
    color: var(--ink);
    font-weight: 500;
    margin-top: 2px;
  }
  .hearing-where .addr {
    font-size: 14px;
    color: var(--text);
  }

  /* Body blocks */
  .block { display: flex; flex-direction: column; gap: 8px; }
  .block .kicker { margin: 0 0 4px; color: var(--ink); }
  .block .copy {
    font-size: 14px;
    line-height: 1.55;
    color: var(--text);
    margin: 0;
    max-width: none;
  }

  /* Numerical figure row */
  .figs {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 4px;
    font-size: 12px;
    color: var(--text-soft);
    letter-spacing: 0.02em;
  }
  .figs b {
    font-weight: 600;
    color: var(--ink);
    margin-right: 4px;
  }

  /* Action list — styled like the brand's "Do" column */
  .actions {
    list-style: none;
    margin: 4px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .actions li {
    font-size: 14px;
    line-height: 1.5;
    color: var(--text);
    padding-left: 22px;
    position: relative;
  }
  .actions li::before {
    content: "+";
    position: absolute;
    left: 0;
    top: 0;
    font-family: var(--mono);
    color: var(--ink);
    font-weight: 600;
  }

  /* Footer wordmark — stamp variant, centered */
  .flyer-foot {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding-top: 24px;
    border-top: 1px solid var(--rule-soft);
  }
  .wordmark {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: stretch;
    text-align: center;
  }
  .wm-rule {
    height: 1px;
    background: var(--ink);
    opacity: 0.6;
  }
  .wm-primary {
    font-family: var(--headline);
    font-size: 28px;
    color: var(--ink);
    line-height: 1;
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .wm-secondary {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    opacity: 0.78;
    font-weight: 500;
  }

  .stamp-line {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-mute);
  }

  /* Print: drop the stage chrome, set page size, hide page background */
  @page { size: letter portrait; margin: 0; }

  @media print {
    .stage { padding: 0; background: var(--paper); min-height: auto; }
    .flyer { box-shadow: none; width: 8.5in; height: 11in; }
    /* Force exact backgrounds for the hearing card and rules */
    * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  }

  /* Narrow screens: let the sheet shrink rather than overflow */
  @media (max-width: 9in) {
    .stage { padding: 16px 8px; }
    .flyer {
      width: 100%;
      max-width: 8.5in;
      min-height: auto;
      padding: 32px 28px 28px;
    }
    .flyer-title { font-size: 40px; }
    .hearing-grid { grid-template-columns: 1fr; gap: 18px; }
    .hearing-when strong { font-size: 24px; }
  }
</style>
