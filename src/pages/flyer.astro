---
import QRCode from 'qrcode';
import BaseLayout from '../layouts/BaseLayout.astro';

const flyer = {
  url: 'foxfirecoalition.org',
  fullUrl: 'https://www.foxfirecoalition.org',
  email: 'info@foxfirecoalition.org',
};

/* Generate the QR as inline SVG at build time. Forest Ink on Cream so
 * the printed mark stays in-system. Quiet zone is built into the SVG. */
const qrSvg = await QRCode.toString(flyer.fullUrl, {
  type: 'svg',
  errorCorrectionLevel: 'M',
  margin: 2,
  color: {
    dark: '#1F3A22',
    light: '#F4EFE3',
  },
});
---
<BaseLayout title="Two data centers. 266 acres. Behind your house. — Homes of Foxfire Coalition">
  <main class="stage" aria-label="Flyer preview">
    <article class="flyer" role="document">

      <header class="masthead">
        <div class="wordmark" aria-label="Homes of Foxfire Coalition Against Data Centers">
          <div class="wm-primary">Homes of Foxfire</div>
          <div class="wm-secondary">Coalition Against Data Centers</div>
        </div>
        <aside class="tagline" aria-hidden="true">
          <div>Our air, Our water, Our land.</div>
          <div class="tagline-em">Our right to know.</div>
        </aside>
      </header>

      <section class="callout">
        <div class="kicker-q">Did you know?</div>
        <h1 class="headline">
          Two data centers.<br />
          266 acres.<br />
          Behind your house.
        </h1>
        <div class="rule" aria-hidden="true"></div>
        <p class="lede">
          A 266-acre Planned Industrial District is proposed for the parcels
          along Foxfire and adjacent lots in Commercial Point, Ohio. Most
          homeowners were not told this at closing.
        </p>
      </section>

      <section class="learn">
        <div class="qr" aria-hidden="true" set:html={qrSvg}></div>
        <div class="learn-copy">
          <h2 class="learn-title">Learn more.</h2>
          <ul class="learn-list">
            <li>What is being proposed.</li>
            <li>When the next public hearing is.</li>
            <li>How to contact your representatives.</li>
          </ul>
          <div class="learn-url">{flyer.url}</div>
        </div>
      </section>

      <footer class="stamp-line">
        <span class="contact">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="1.2" />
            <path d="M3.5 6.5l8.5 6 8.5-6" />
          </svg>
          {flyer.email}
        </span>
        <span class="contact">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="9" />
            <path d="M3 12h18" />
            <path d="M12 3c2.8 3 4.2 6 4.2 9s-1.4 6-4.2 9" />
            <path d="M12 3c-2.8 3-4.2 6-4.2 9s1.4 6 4.2 9" />
          </svg>
          {flyer.url}
        </span>
      </footer>

    </article>
  </main>
</BaseLayout>

<style>
  /* Stage — only visible on screen. */
  .stage {
    min-height: 100vh;
    padding: 32px 16px;
    background: var(--bone);
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .flyer {
    width: 8.5in;
    height: 11in;
    padding: 0.6in 0.65in;
    background: var(--paper);
    color: var(--text);
    box-shadow: 0 1px 2px rgba(0,0,0,0.06), 0 12px 40px rgba(0,0,0,0.12);
    display: grid;
    grid-template-rows: auto 1fr auto auto;
    gap: 0.42in;
    overflow: hidden;
  }

  /* Masthead — wordmark left, tagline right */
  .masthead {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
  }

  /* Wordmark — top-left, stacked variant */
  .wordmark {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-start;
  }

  /* Tagline — top-right counter-weight to the wordmark */
  .tagline {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: right;
    font-family: var(--mono);
    font-size: 11px;
    line-height: 1.5;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    font-weight: 500;
    padding-top: 6px;
  }
  .tagline-em { color: var(--accent); }
  .wm-primary {
    font-family: var(--headline);
    font-size: 30px;
    line-height: 1;
    color: var(--ink);
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .wm-secondary {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    opacity: 0.78;
    font-weight: 500;
  }

  /* Headline + lede — the call to action zone */
  .callout {
    display: flex;
    flex-direction: column;
    gap: 0.35in;
    justify-content: center;
  }
  .kicker-q {
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: -0.25in;
    font-weight: 500;
  }
  .headline {
    font-family: var(--headline);
    font-size: 88px;
    line-height: 1.0;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.02em;
    font-weight: 500;
    text-wrap: balance;
  }
  .rule {
    height: 6px;
    background: var(--accent);
    width: 1.6in;
  }
  .lede {
    font-family: var(--body);
    font-size: 19px;
    line-height: 1.5;
    color: var(--text);
    margin: 0;
    max-width: 6.5in;
    text-wrap: pretty;
  }

  /* Learn more zone — QR left, instructions right */
  .learn {
    display: grid;
    grid-template-columns: 1.7in 1fr;
    gap: 0.4in;
    align-items: start;
    padding-top: 0.2in;
    border-top: 1px solid var(--rule-soft);
  }
  .qr {
    width: 1.7in;
    height: 1.7in;
    background: var(--paper);
    border: 1px solid var(--rule-soft);
    padding: 4px;
  }
  .qr :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }
  .learn-copy {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 4px;
  }
  .learn-title {
    font-family: var(--headline);
    font-size: 28px;
    line-height: 1;
    color: var(--ink);
    margin: 0 0 4px;
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .learn-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .learn-list li {
    font-size: 16px;
    line-height: 1.4;
    color: var(--text);
    padding-left: 18px;
    position: relative;
  }
  .learn-list li::before {
    content: "+";
    position: absolute;
    left: 0;
    top: 0;
    font-family: var(--mono);
    color: var(--ink);
    font-weight: 600;
  }
  .learn-url {
    margin-top: 6px;
    font-family: var(--mono);
    font-size: 15px;
    color: var(--accent);
    letter-spacing: 0.02em;
  }

  /* Footer stamp line — contact info, natural case */
  .stamp-line {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--rule-soft);
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .stamp-line .contact {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .stamp-line .icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Print: drop the stage chrome, set page size, hide page background */
  @page { size: letter portrait; margin: 0; }

  @media print {
    .stage { padding: 0; background: var(--paper); min-height: auto; }
    .flyer { box-shadow: none; width: 8.5in; height: 11in; }
    * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  }

  /* Narrow screens: let the sheet shrink rather than overflow.
     Scoped to screen — print always renders the full letter sheet. */
  @media screen and (max-width: 9in) {
    .stage { padding: 16px 8px; }
    .flyer {
      width: 100%;
      max-width: 8.5in;
      height: auto;
      padding: 32px 28px;
      gap: 28px;
    }
    .headline { font-size: 56px; }
    .learn { grid-template-columns: 1.5in 1fr; gap: 24px; }
    .qr { width: 1.5in; height: 1.5in; }
    .masthead { flex-wrap: wrap; }
  }
</style>
