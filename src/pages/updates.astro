---
import SiteLayout from '../layouts/SiteLayout.astro';

const lastUpdated = '04.29 / 2026';
---

<SiteLayout
  title="Updates | Foxfire Coalition"
  description="News and changes from the Foxfire Coalition: records-request status, meeting reminders, newly found documents, and volunteer needs."
  lastUpdated={lastUpdated}
>
  <section class="page-section page-section-tier" style="min-height: 80vh;">
    <div class="measure">
      <p class="kicker">Updates</p>
      <h1 style="font-family: var(--headline); font-size: clamp(2rem, 3.8vw, 3rem); line-height: 1.15; margin: 0 0 var(--space-md);">Coming soon.</h1>
      <p class="lede">
        Coalition updates will be posted here: meeting recaps, records-request
        status, newly found documents, and volunteer needs. Check back soon.
      </p>
    </div>
  </section>
</SiteLayout>
