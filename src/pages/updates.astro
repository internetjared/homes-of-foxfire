---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeading from '../components/content/SectionHeading.astro';

const lastUpdated = '04.25 / 2026';

// UpdatePost rendering from src/data/updates.json arrives in the next two
// commits (data file, then UpdatePost component). The page intro and
// records-request status block ship now so the route exists in nav and
// SEO indexes correctly from day one.
---

<SiteLayout
  title="Updates | Foxfire Coalition"
  description="Records-request status, meeting reminders and recaps, newly found documents, and volunteer needs from the Foxfire Coalition."
  lastUpdated={lastUpdated}
>
  <section class="page-section page-section-tier">
    <div class="measure">
      <SectionHeading kicker="Updates" title="What is new from the coalition." />
      <p class="lede">
        News and changes from the coalition: records-request status, meeting reminders and
        recaps, newly found documents, timeline updates, and volunteer needs.
      </p>
      <p>
        We believe residents deserve complete, accessible, and timely information about major
        development decisions affecting their homes, health, water, roads, and quality of life.
      </p>
    </div>
  </section>

  <!-- UpdatePost list renders from src/data/updates.json once the data
       file and component land in the next commits. -->
  <section id="posts" class="page-section">
    <div class="measure">
      <p class="lede">
        First posts coming with the next data load. The first post will mark
        <span class="mono tab">FXF-PR-2026-001</span>, the coalition's first public records
        request to the Village Fiscal Officer.
      </p>
    </div>
  </section>

  <!-- Records-request status (static block; live tracker is Phase 2) -->
  <section id="prr-status" class="page-section">
    <div class="measure">
      <SectionHeading kicker="Records requests" title="Status of pending requests." />
      <dl class="status-table">
        <div class="status-row">
          <dt><span class="mono tab">FXF-PR-2026-001</span></dt>
          <dd>
            First request: Ordinance 2024-07, the Special Council Meeting record, the
            Jahn Property Industrial Major Site Plan, and related materials.
            <span class="status-tag status-pending">Pending</span>
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Disclaimer (procedural matters) -->
  <section class="page-section">
    <div class="measure">
      <div class="disclaimer">
        <p>
          The Homes of Foxfire Coalition is a volunteer neighborhood organization. Nothing on
          this site is legal advice. Residents who believe they have a legal interest in any
          matter described here should consult a licensed attorney.
        </p>
      </div>
    </div>
  </section>
</SiteLayout>
