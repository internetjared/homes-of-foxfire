---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeading from '../components/content/SectionHeading.astro';
import DocumentCard from '../components/content/DocumentCard.astro';
import documents from '../data/documents.json';

type Kind =
  | 'ordinance'
  | 'resolution'
  | 'minutes'
  | 'hearing'
  | 'agenda'
  | 'packet'
  | 'agreement'
  | 'study'
  | 'correspondence'
  | 'other';

const lastUpdated = '04.25 / 2026';

// Render in the order they appear in documents.json. Category-grouped
// rendering lands in the next commit, after the data file is backfilled
// with the category field per docs/CONTENT.md.
---

<SiteLayout
  title="Public documents | Foxfire data center records"
  description="Access public records, ordinances, meeting minutes, site plans, and records requests related to the Foxfire-adjacent K-Nova / Jahn Farm data-center issue."
  lastUpdated={lastUpdated}
>
  <section class="page-section page-section-tier">
    <div class="measure">
      <SectionHeading kicker="Documents" title="Public documents." />
      <p class="lede">
        These are public records, ordinances, meeting minutes, site plans, records requests,
        and research materials related to the Foxfire / K-Nova / Jahn Farm data-center issue.
        We are organizing them so residents can review the source material directly.
      </p>
      <p>
        We believe residents deserve complete, accessible, and timely information about major
        development decisions affecting their homes, health, water, roads, and quality of life.
      </p>
    </div>
  </section>

  <section id="library" class="page-section">
    <div class="measure-wide">
      <div class="doc-grid">
        {documents.map((doc) => (
          <DocumentCard
            kind={doc.kind as Kind}
            number={doc.number}
            title={doc.title}
            date={doc.date}
            body={doc.body}
            source={doc.source}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Disclaimer (procedural matters) -->
  <section class="page-section">
    <div class="measure">
      <div class="disclaimer">
        <p>
          The Homes of Foxfire Coalition is a volunteer neighborhood organization. Nothing on
          this site is legal advice. Residents who believe they have a legal interest in any
          matter described here should consult a licensed attorney.
        </p>
      </div>
    </div>
  </section>
</SiteLayout>
