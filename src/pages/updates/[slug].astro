---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Icon from '../../components/content/Icon.astro';
import ShareBar from '../../components/content/ShareBar.astro';
import {
  getAllUpdates,
  isLocalVideo,
  toEmbedUrl,
  ogImageForUpdate,
  type LocalUpdate,
} from '../../data/updates';

export async function getStaticPaths() {
  const all = await getAllUpdates();
  return all.map((u) => ({
    params: { slug: u.id },
    props: { update: u },
  }));
}

interface Props {
  update: LocalUpdate;
}

const { update } = Astro.props as Props;

const lastUpdated = '04.30 / 2026';
const localVideo = isLocalVideo(update.videoUrl);
const embedUrl = !localVideo ? toEmbedUrl(update.videoUrl) : null;

const description = update.excerpt;
const postUrl = `https://foxfirecoalition.org/updates/${update.id}`;

// SEO: use a full-size YouTube thumbnail (or post-specific override) for the
// OG image. maxresdefault.jpg is 1280x720 — proper social-preview sizing.
const SITE_URL = 'https://foxfirecoalition.org';
const ogImageUrl = ogImageForUpdate(update);
const ogImage = ogImageUrl ?? `${SITE_URL}/FCADC_Social.jpg`;

// Resolve an absolute OG image URL for JSON-LD (relative paths must be absolute).
const absoluteOgImage = ogImageUrl
  ? (ogImageUrl.startsWith('http') ? ogImageUrl : `${SITE_URL}${ogImageUrl}`)
  : `${SITE_URL}/FCADC_Social.jpg`;

// Image dimensions: use post-level overrides, or fall back to YouTube maxresdefault
// (1280×720), or the site default image.
const ogImageWidth  = update.ogImageWidth  ?? (ogImageUrl && !ogImageUrl.startsWith('/') ? 1280 : 1445);
const ogImageHeight = update.ogImageHeight ?? (ogImageUrl && !ogImageUrl.startsWith('/') ? 720  : 854);

// Article (NewsArticle) JSON-LD — gives blog posts proper schema.org markup
// so search engines can surface date, author, and headline in rich results.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: update.title,
  description: update.excerpt,
  image: [{
    '@type': 'ImageObject',
    url: absoluteOgImage,
    width: ogImageWidth,
    height: ogImageHeight,
  }],
  datePublished: `${update.publishDate}T00:00:00-05:00`,
  dateModified:  `${update.publishDate}T00:00:00-05:00`,
  author: {
    '@type': 'Organization',
    name: 'Homes of Foxfire Coalition',
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Homes of Foxfire Coalition',
    logo: {
      '@type': 'ImageObject',
      url: `${SITE_URL}/favicon.png`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${SITE_URL}/updates/${update.id}`,
  },
  articleSection: update.category,
};
---

<SiteLayout
  title={`${update.title} | Foxfire Coalition`}
  description={description}
  lastUpdated={lastUpdated}
  type="article"
  image={ogImage}
  imageWidth={ogImageWidth}
  imageHeight={ogImageHeight}
  noindex={update.draft}
  articleMeta={{
    publishedTime: `${update.publishDate}T00:00:00-05:00`,
    modifiedTime:  `${update.publishDate}T00:00:00-05:00`,
    section: update.category,
    authorName: 'Homes of Foxfire Coalition',
  }}
  extraSchema={articleSchema}
>
  <nav class="update-back-nav" aria-label="Back to updates">
    <a href="/updates">
      <Icon name="arrow-right" size={12} />
      <span>All updates</span>
    </a>
  </nav>

  <article class="update-article" id={update.id}>
    <header class="update-article-head">
      <p class="update-article-meta">
        <span class="update-article-date mono tab">{update.publishDateLabel}</span>
        <span class="update-article-dot" aria-hidden="true">·</span>
        <span class="update-article-category">{update.category}</span>
      </p>
      <h1 class="update-article-title">{update.title}</h1>
    </header>

    {(localVideo || embedUrl) && (
      <figure class="update-article-video">
        <div class="update-video-frame">
          {localVideo ? (
            <video
              src={update.videoUrl}
              poster={update.videoPoster}
              controls
              preload="metadata"
              playsinline
            >
              Your browser does not support embedded video.
              <a href={update.videoUrl}>Download the video</a> to watch it.
            </video>
          ) : (
            <iframe
              src={embedUrl!}
              title={update.videoTitle || update.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          )}
        </div>
        {update.videoTitle && <figcaption class="update-video-caption">{update.videoTitle}</figcaption>}
      </figure>
    )}

    <div class="update-article-body" set:html={update.bodyHtml}></div>

    <div class="update-article-share">
      <ShareBar url={postUrl} title={update.title} />
    </div>

    <footer class="update-article-foot">
      <a class="update-article-back-link" href="/updates">
        <Icon name="arrow-right" size={12} />
        <span>Back to all updates</span>
      </a>
    </footer>
  </article>
</SiteLayout>

<style>
  .update-article {
    max-width: 920px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) var(--space-4xl);
  }

  /* Back nav — full-width, aligned to the page frame (same as the header logo) */
  .update-back-nav {
    max-width: var(--frame);
    margin-inline: auto;
    padding: var(--space-xl) var(--space-lg) 0;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .update-back-nav a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-soft);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .update-back-nav a:hover,
  .update-back-nav a:focus-visible {
    color: var(--ink);
  }

  /* Arrow flipped left; colored accent red independently of the label text */
  .update-back-nav :global(svg) {
    transform: scaleX(-1);
    color: var(--accent);
    flex-shrink: 0;
  }

  .update-article-head {
    max-width: 760px;
    margin: 0 auto var(--space-xl);
    text-align: center;
  }

  .update-article-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
    align-items: baseline;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-soft);
    margin: 0 0 var(--space-md);
  }

  .update-article-date {
    color: var(--ink);
    font-feature-settings: "tnum";
  }

  .update-article-dot {
    color: var(--rule-soft);
  }

  .update-article-title {
    font-family: var(--headline);
    font-size: clamp(1.75rem, 3.4vw, 2.75rem);
    line-height: 1.15;
    margin: 0;
    text-wrap: balance;
    color: var(--ink);
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  /* Video ------------------------------------------------------------- */

  .update-article-video {
    margin: 0 0 var(--space-2xl);
  }

  .update-video-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--ink);
    overflow: hidden;
  }

  .update-video-frame iframe,
  .update-video-frame video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    object-fit: contain;
    background: var(--ink);
  }

  .update-video-caption {
    margin: var(--space-sm) 0 0;
    font-size: 14px;
    color: var(--text-soft);
    text-align: left;
    max-width: 720px;
    margin-inline: auto;
  }

  /* Body -------------------------------------------------------------- */

  .update-article-body {
    max-width: 720px;
    margin: 0 auto;
    font-size: 17px;
    line-height: 1.65;
    color: var(--text);
  }

  .update-article-body :global(h2) {
    font-family: var(--headline);
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    line-height: 1.25;
    margin: var(--space-2xl) 0 var(--space-md);
    color: var(--ink);
    font-weight: 500;
    text-wrap: balance;
  }

  .update-article-body :global(p) {
    margin: 0 0 var(--space-md);
  }

  .update-article-body :global(ul) {
    margin: var(--space-md) 0 var(--space-lg);
    padding-left: 1.25em;
  }

  .update-article-body :global(li) {
    margin-bottom: var(--space-xs);
  }

  .update-article-body :global(a) {
    color: var(--accent);
    border-bottom: 1px solid currentColor;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .update-article-body :global(a:hover),
  .update-article-body :global(a:focus-visible) {
    opacity: 0.7;
  }

  .update-article-body :global(.update-sources) {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--rule-soft);
  }

  .update-article-body :global(.update-sources-title) {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-soft);
    margin: 0 0 var(--space-xs);
  }

  .update-article-body :global(.update-sources-intro) {
    font-size: 14px;
    color: var(--text-soft);
    margin: 0 0 var(--space-lg);
  }

  .update-article-body :global(.update-sources h3) {
    font-family: var(--headline);
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    margin: var(--space-lg) 0 var(--space-xs);
    letter-spacing: 0.01em;
  }

  .update-article-body :global(.update-sources ul) {
    list-style: none;
    padding-left: 0;
    margin: 0 0 var(--space-md);
  }

  .update-article-body :global(.update-sources li) {
    font-size: 14px;
    line-height: 1.5;
    margin-bottom: var(--space-xs);
  }

  .update-article-body :global(.update-pull) {
    margin: var(--space-2xl) 0 var(--space-xl);
    padding: var(--space-xl);
    border-left: 3px solid var(--accent);
    background: var(--bone);
    font-size: 19px;
    line-height: 1.4;
    color: var(--ink);
  }

  .update-article-body :global(.update-callout) {
    margin: var(--space-xl) 0;
    padding: var(--space-lg) var(--space-xl);
    background: var(--ink);
    color: var(--paper);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  /* Contacts block -------------------------------------------------- */

  .update-article-body :global(.update-contacts) {
    margin: var(--space-xl) 0;
    border: 1px solid var(--rule-soft);
    border-radius: 4px;
    overflow: hidden;
  }

  .update-article-body :global(.update-contacts-intro) {
    margin: 0;
    padding: var(--space-md) var(--space-lg);
    font-size: 14px;
    color: var(--text-soft);
    border-bottom: 1px solid var(--rule-soft);
    background: var(--bone);
  }

  .update-article-body :global(.update-contacts-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .update-article-body :global(.update-contact-item) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-sm) var(--space-lg);
    border-bottom: 1px solid var(--rule-soft);
    border-right: 1px solid var(--rule-soft);
  }

  .update-article-body :global(.update-contact-item:nth-child(even)) {
    border-right: none;
  }

  .update-article-body :global(.update-contact-item:nth-last-child(-n+2)) {
    border-bottom: none;
  }

  .update-article-body :global(.update-contact-role) {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-soft);
  }

  .update-article-body :global(.update-contact-email) {
    font-size: 13px;
    font-family: var(--mono);
    color: var(--accent);
    text-decoration: none;
    border-bottom: none;
    word-break: break-all;
  }

  .update-article-body :global(.update-contact-email:hover) {
    text-decoration: underline;
    opacity: 1;
  }

  .update-article-body :global(.update-contact-name) {
    font-size: 13px;
    color: var(--ink);
  }

  .update-article-body :global(.update-contacts-copy-all) {
    display: block;
    width: 100%;
    padding: var(--space-sm) var(--space-lg);
    background: none;
    border: none;
    border-top: 1px solid var(--rule-soft);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    cursor: pointer;
    text-align: left;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .update-article-body :global(.update-contacts-copy-all:hover) {
    background: var(--bone);
    color: var(--ink);
  }

  /* Email template -------------------------------------------------- */

  .update-article-body :global(.update-email-template) {
    margin: var(--space-xl) 0;
    border: 1px solid var(--rule-soft);
    border-radius: 4px;
    overflow: hidden;
  }

  .update-article-body :global(.update-email-template-head) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-lg);
    background: var(--bone);
    border-bottom: 1px solid var(--rule-soft);
  }

  .update-article-body :global(.update-email-subject) {
    margin: 0;
    font-size: 13px;
    color: var(--ink);
  }

  .update-article-body :global(.update-email-copy-btn) {
    flex-shrink: 0;
    padding: 5px 14px;
    background: var(--ink);
    color: var(--paper);
    border: none;
    border-radius: 3px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }

  .update-article-body :global(.update-email-copy-btn:hover) {
    opacity: 0.75;
  }

  .update-article-body :global(.update-email-body) {
    padding: var(--space-lg) var(--space-xl);
    font-size: 15px;
    line-height: 1.6;
    color: var(--text);
    background: var(--paper);
  }

  .update-article-body :global(.update-email-body p) {
    margin: 0 0 var(--space-sm);
  }

  .update-article-body :global(.update-email-body p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 600px) {
    .update-article-body :global(.update-contacts-grid) {
      grid-template-columns: 1fr;
    }

    .update-article-body :global(.update-contact-item) {
      border-right: none;
    }

    .update-article-body :global(.update-contact-item:nth-last-child(-n+2)) {
      border-bottom: 1px solid var(--rule-soft);
    }

    .update-article-body :global(.update-contact-item:last-child) {
      border-bottom: none;
    }

    .update-article-body :global(.update-email-template-head) {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  /* Copy toast -------------------------------------------------------- */

  :global(.update-copy-toast) {
    position: fixed;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%) translateY(12px);
    background: var(--ink);
    color: var(--paper);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 10px 20px;
    border-radius: 3px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
    z-index: 9999;
    white-space: nowrap;
  }

  :global(.update-copy-toast.is-visible) {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Share bar -------------------------------------------------------- */

  .update-article-share {
    max-width: 720px;
    margin: var(--space-2xl) auto 0;
  }

  /* Footer back link ------------------------------------------------- */

  .update-article-foot {
    max-width: 720px;
    margin: var(--space-3xl) auto 0;
    padding-top: var(--space-xl);
    border-top: 1px solid var(--rule-soft);
  }

  .update-article-back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-soft);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .update-article-back-link:hover,
  .update-article-back-link:focus-visible {
    color: var(--ink);
  }

  .update-article-back-link :global(svg) {
    transform: scaleX(-1);
    color: var(--accent);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .update-article {
      padding: var(--space-xl) var(--space-lg) var(--space-3xl);
    }

    .update-article-title {
      font-size: clamp(1.5rem, 6vw, 2rem);
    }

    .update-article-body {
      font-size: 16px;
    }
  }
</style>
