---
import SiteLayout from '../layouts/SiteLayout.astro';
import Icon from '../components/content/Icon.astro';
import featured from '../data/featured.json';

const lastUpdated = '04.30 / 2026';

interface FeaturedItem {
  kind: 'video' | 'ordinance' | 'resolution' | 'code' | 'document' | 'site-plan';
  date: string;
  label: string;
  title: string;
  summary: string;
  url?: string;
  url_label?: string;
  secondary_url?: string;
  secondary_label?: string;
  tertiary_url?: string;
  tertiary_label?: string;
}

const items = featured as FeaturedItem[];

// Chronological order — read top to bottom as the K-Nova story.
const sorted = [...items].sort((a, b) => a.date.localeCompare(b.date));

const formatDate = (iso: string) => {
  const d = new Date(iso + 'T12:00:00');
  const mm = String(d.getMonth() + 1).padStart(2, '0');
  const dd = String(d.getDate()).padStart(2, '0');
  return `${mm}.${dd} / ${d.getFullYear()}`;
};

const kindLabel = (k: string) =>
  k === 'video' ? 'Meeting'
  : k === 'ordinance' ? 'Ordinance'
  : k === 'resolution' ? 'Resolution'
  : k === 'code' ? 'Zoning code'
  : k === 'site-plan' ? 'Site plan'
  : 'Document';

const itemCount = sorted.length;

// Total source links across primary, secondary, and tertiary URL slots.
// Surfaced in the Sourcing section so the count stays honest if data changes.
const sourceLinkCount = sorted.reduce(
  (sum, item) =>
    sum + (item.url ? 1 : 0) + (item.secondary_url ? 1 : 0) + (item.tertiary_url ? 1 : 0),
  0,
);

// Detect whether a URL points to a video (YouTube). Used to swap the action-button
// trailing icon and to flag video entries in the date column.
const isVideoUrl = (url?: string) =>
  Boolean(url && (url.includes('youtube.com') || url.includes('youtu.be')));

const entryHasVideo = (item: FeaturedItem) =>
  isVideoUrl(item.url) || isVideoUrl(item.secondary_url) || isVideoUrl(item.tertiary_url);

// Local reference assets (PDFs, denial letter PNGs, etc.) live under /Reference_*.
// These open in an in-page iframe lightbox instead of navigating away.
const isLocalReference = (url?: string) => Boolean(url && url.startsWith('/Reference_'));
---

<SiteLayout
  title="Timeline | Foxfire Coalition"
  description="The full K-Nova / Jahn Farm public-record timeline. Every council meeting, ordinance, resolution, and document at the center of the rezoning, in chronological order, with sources where available."
  lastUpdated={lastUpdated}
>
  <!-- Hero -->
  <section class="page-section page-section-tier media-hero">
    <div class="measure">
      <p class="kicker">Timeline</p>
      <h1 class="media-title">Watch the meetings.<br />Read the record.</h1>
      <p class="lede">
        The K-Nova story in source form. Every council meeting, ordinance, and document
        we have a public link for, in chronological order. More entries will be added
        here as records are received and verified.
      </p>
    </div>
  </section>

  <!-- The record: chronological ledger -->
  <section class="page-section media-record" aria-label="K-Nova timeline, chronological">
    <div class="measure-wide">
      <ol class="record-list">
        {sorted.map((item) => (
          <li class="record-row">
            <div class="record-date-col">
              <span class="record-date mono tab">{formatDate(item.date)}</span>
              <span class="record-kind">
                {entryHasVideo(item) && (
                  <span class="record-kind-video" aria-label="Video available">
                    <Icon name="play" size={9} />
                  </span>
                )}
                {kindLabel(item.kind)}
              </span>
            </div>
            <div class="record-body">
              <p class="record-label">{item.label}</p>
              <h2 class="record-title">{item.title}</h2>
              <p class="record-summary">{item.summary}</p>
              <div class="record-actions">
                {item.url && item.url_label && (
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener"
                    class={`record-link${isVideoUrl(item.url) ? ' record-link-video' : ''}`}
                    data-lightbox-url={isLocalReference(item.url) ? item.url : undefined}
                    data-lightbox-title={isLocalReference(item.url) ? `${kindLabel(item.kind)}: ${item.title}` : undefined}
                  >
                    {isVideoUrl(item.url)
                      ? <Icon name="play" size={11} />
                      : null}
                    {item.url_label}
                    {!isVideoUrl(item.url) && <Icon name="arrow-right" size={12} />}
                  </a>
                )}
                {item.secondary_url && (
                  <a
                    href={item.secondary_url}
                    target="_blank"
                    rel="noopener"
                    class={`record-link record-link-secondary${isVideoUrl(item.secondary_url) ? ' record-link-video' : ''}`}
                    data-lightbox-url={isLocalReference(item.secondary_url) ? item.secondary_url : undefined}
                    data-lightbox-title={isLocalReference(item.secondary_url) ? `${kindLabel(item.kind)}: ${item.title}` : undefined}
                  >
                    {isVideoUrl(item.secondary_url)
                      ? <Icon name="play" size={11} />
                      : null}
                    {item.secondary_label}
                    {!isVideoUrl(item.secondary_url) && <Icon name="arrow-right" size={12} />}
                  </a>
                )}
                {item.tertiary_url && (
                  <a
                    href={item.tertiary_url}
                    target="_blank"
                    rel="noopener"
                    class={`record-link record-link-secondary${isVideoUrl(item.tertiary_url) ? ' record-link-video' : ''}`}
                    data-lightbox-url={isLocalReference(item.tertiary_url) ? item.tertiary_url : undefined}
                    data-lightbox-title={isLocalReference(item.tertiary_url) ? `${kindLabel(item.kind)}: ${item.title}` : undefined}
                  >
                    {isVideoUrl(item.tertiary_url)
                      ? <Icon name="play" size={11} />
                      : null}
                    {item.tertiary_label}
                    {!isVideoUrl(item.tertiary_url) && <Icon name="arrow-right" size={12} />}
                  </a>
                )}
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Sourcing & verification -->
  <section class="page-section media-sourcing" aria-labelledby="sourcing-heading">
    <div class="measure">
      <p class="kicker">Sourcing</p>
      <h2 id="sourcing-heading" class="sourcing-title">How this record is verified.</h2>
      <p>
        The <span class="mono">{itemCount}</span> entries above are anchored to
        <span class="mono">{sourceLinkCount}</span> working source links: village
        ordinances, council and committee minutes, special meeting minutes, public
        hearing minutes, the village's YouTube channel, and Pickaway County records.
        Every PDF and video URL on this page has been opened and confirmed to load
        the expected document.
      </p>
      <p>
        Two statements on this page are drawn from coalition research notes rather
        than from a single linked document. The underlying language will be quoted
        directly once those source materials are obtained:
      </p>
      <ul class="sourcing-notes">
        <li>The phrase "extenuating circumstances" cited at the April 15, 2024 special meeting.</li>
        <li>The 48-hour resubmission requirement that followed the April 15 waiver.</li>
      </ul>
      <p class="sourcing-foot">
        Last verified <span class="mono">{lastUpdated}</span>.
      </p>
    </div>
  </section>

  <!-- Pre-footer -->
  <section class="pre-footer">
    <div class="pre-footer-inner">
      <p class="pre-footer-kicker">Help fill the gaps.</p>
      <h2 class="pre-footer-title">
        See a missing record?<br />Tell us.
      </h2>
      <p class="pre-footer-body">
        If you know of a meeting, document, or news segment that should be on this page,
        send it to the coalition. We will source-check it and add it.
      </p>
      <p class="pre-footer-ctas">
        <a class="btn-primary" href="/take-action">Take action <Icon name="megaphone" size={14} /></a>
      </p>
    </div>
  </section>

  <!-- Reference document lightbox: site plan PDF, denial letter PNG, etc.
       Triggered by any link with [data-lightbox-url]. Reuses the .plan-lightbox
       styling from components.css (same chrome as the homepage proposed-plan modal). -->
  <div
    class="plan-lightbox"
    id="ref-lightbox"
    role="dialog"
    aria-modal="true"
    aria-labelledby="ref-lightbox-title"
    hidden
  >
    <div class="plan-lightbox-backdrop" data-close-lightbox></div>
    <div class="plan-lightbox-frame">
      <div class="plan-lightbox-header">
        <p class="plan-lightbox-title" id="ref-lightbox-title">Reference document</p>
        <button class="plan-lightbox-close" type="button" data-close-lightbox aria-label="Close reference document">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
      <div class="plan-lightbox-body">
        <iframe
          class="plan-lightbox-iframe"
          id="ref-lightbox-iframe"
          title="Reference document"
          src=""
        ></iframe>
      </div>
    </div>
  </div>
</SiteLayout>

<style>
  .media-hero {
    padding-top: var(--space-2xl);
  }

  .media-title {
    font-family: var(--headline);
    font-size: clamp(2rem, 3.8vw, 3rem);
    line-height: 1.1;
    margin: 0 0 var(--space-md);
  }

  .media-record {
    padding-top: var(--space-md);
  }

  .record-list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: record;
  }

  .record-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-2xl);
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--rule-soft);
    align-items: start;
  }

  .record-row:last-child {
    border-bottom: 1px solid var(--rule-soft);
  }

  .record-date-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    position: sticky;
    top: calc(var(--sticky-bar-h, 52px) + var(--header-h, 114px) + var(--space-md));
    align-self: start;
  }

  .record-date {
    font-size: 15px;
    color: var(--ink);
    font-weight: 500;
    letter-spacing: 0.02em;
    font-feature-settings: "tnum";
    line-height: 1.2;
  }

  .record-kind {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-soft);
  }

  /* Small play badge that flags entries with a YouTube link in the date column. */
  .record-kind-video {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--paper-2);
  }

  .record-kind-video :global(svg) {
    margin-left: 1px; /* nudge the play triangle visually centered in the circle */
  }

  .record-body {
    min-width: 0;
    max-width: 64ch;
  }

  .record-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-soft);
    margin: 0 0 var(--space-xs);
  }

  .record-title {
    font-family: var(--headline);
    font-size: clamp(1.125rem, 1.6vw, 1.375rem);
    line-height: 1.25;
    font-weight: 500;
    margin: 0 0 var(--space-sm);
    color: var(--ink);
    text-wrap: balance;
  }

  .record-summary {
    font-size: 16px;
    line-height: 1.55;
    color: var(--text);
    margin: 0 0 var(--space-md);
  }

  .record-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-lg);
  }

  .record-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--body);
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
    transition: opacity 0.15s ease;
  }

  .record-link:hover {
    opacity: 0.7;
  }

  .record-link-secondary {
    color: var(--text-soft);
    border-bottom-color: var(--rule-soft);
    font-weight: 400;
  }

  /* Video link variant — leading play icon, accent stroke under the label. */
  .record-link-video {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .record-link-video.record-link-secondary {
    color: var(--accent);
    border-bottom-color: var(--accent);
    opacity: 0.85;
  }

  /* Sourcing section */
  .media-sourcing {
    border-top: 1px solid var(--rule-soft);
    padding-top: var(--space-2xl);
  }

  .sourcing-title {
    font-family: var(--headline);
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    line-height: 1.2;
    margin: var(--space-xs) 0 var(--space-md);
    font-weight: 500;
  }

  .media-sourcing p {
    font-size: 16px;
    line-height: 1.55;
    color: var(--text);
    margin: 0 0 var(--space-md);
  }

  .sourcing-notes {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-lg);
  }

  .sourcing-notes li {
    padding: var(--space-sm) 0;
    border-top: 1px solid var(--rule-soft);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--text);
  }

  .sourcing-notes li:last-child {
    border-bottom: 1px solid var(--rule-soft);
  }

  .sourcing-foot {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-soft);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0;
  }

  @media (max-width: 768px) {
    .record-row {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
      padding: var(--space-lg) 0;
    }

    .record-date-col {
      position: static;
      flex-direction: row;
      align-items: baseline;
      gap: var(--space-md);
    }

    .record-actions {
      gap: var(--space-md);
    }
  }
</style>

<script>
  // Reference-document lightbox.
  //
  // Any link in this page with [data-lightbox-url] is intercepted on click and
  // its target opens inside the in-page iframe instead of navigating away.
  // External links (council minutes on commercialpointohio.gov, YouTube, etc.)
  // do NOT carry that data attribute — they keep their normal target="_blank"
  // behavior. If JS fails for any reason, the [data-lightbox-url] links still
  // work as plain target="_blank" links.
  //
  // Same close-race fix as the homepage proposed-plan lightbox: setTimeout
  // instead of transitionend, cancellable by a re-open.
  (function () {
    if ((window as any).__refLightboxInit) return;
    (window as any).__refLightboxInit = true;

    let lastFocus: HTMLElement | null = null;
    let closeTimer: number | null = null;

    const findEls = () => ({
      lightbox: document.getElementById('ref-lightbox'),
      iframe: document.getElementById('ref-lightbox-iframe') as HTMLIFrameElement | null,
      titleEl: document.getElementById('ref-lightbox-title'),
    });

    const open = (url: string, title: string) => {
      const { lightbox, iframe, titleEl } = findEls();
      if (!lightbox || !iframe || !titleEl) return;

      if (closeTimer !== null) {
        clearTimeout(closeTimer);
        closeTimer = null;
      }
      iframe.src = url;
      titleEl.textContent = title || 'Reference document';
      lightbox.removeAttribute('hidden');
      requestAnimationFrame(() => lightbox.classList.add('is-open'));
      document.body.style.overflow = 'hidden';
      lastFocus = document.activeElement as HTMLElement;
      lightbox.querySelector<HTMLElement>('.plan-lightbox-close')?.focus();
    };

    const close = () => {
      const { lightbox, iframe } = findEls();
      if (!lightbox) return;
      lightbox.classList.remove('is-open');
      document.body.style.overflow = '';
      lastFocus?.focus();
      if (closeTimer !== null) clearTimeout(closeTimer);
      closeTimer = window.setTimeout(() => {
        if (!lightbox.classList.contains('is-open')) {
          lightbox.setAttribute('hidden', '');
          if (iframe) iframe.src = '';
        }
        closeTimer = null;
      }, 400);
    };

    // Click delegation on document so this works across view transitions
    // and however many [data-lightbox-url] links exist now or in the future.
    document.addEventListener('click', (e) => {
      const target = e.target as Element | null;
      if (!target) return;

      const trigger = target.closest<HTMLAnchorElement>('a[data-lightbox-url]');
      if (trigger) {
        e.preventDefault();
        const url = trigger.dataset.lightboxUrl ?? '';
        const title = trigger.dataset.lightboxTitle ?? '';
        if (url) open(url, title);
        return;
      }

      if (target.closest('#ref-lightbox [data-close-lightbox]')) {
        close();
      }
    });

    document.addEventListener('keydown', (e) => {
      const { lightbox } = findEls();
      if (e.key === 'Escape' && lightbox && !lightbox.hidden) close();
    });
  })();
</script>
