---
import SiteLayout from '../layouts/SiteLayout.astro';

const lastUpdated = '04.29 / 2026';
---

<SiteLayout
  title="Timeline | Foxfire Coalition"
  description="A source-linked public-record timeline of the K-Nova / Jahn Farm data-center zoning and site-plan issue near Foxfire in Commercial Point, Ohio."
  lastUpdated={lastUpdated}
>
  <section class="page-section page-section-tier" style="min-height: 80vh;">
    <div class="measure">
      <p class="kicker">Timeline</p>
      <h1 style="font-family: var(--headline); font-size: clamp(2rem, 3.8vw, 3rem); line-height: 1.15; margin: 0 0 var(--space-md);">Coming soon.</h1>
      <p class="lede">
        A full source-linked timeline of the K-Nova / Jahn Farm data-center
        rezoning is being prepared. Check back soon.
      </p>
    </div>
  </section>
</SiteLayout>
