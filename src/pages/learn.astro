---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeading from '../components/content/SectionHeading.astro';
import ResourceCard from '../components/content/ResourceCard.astro';
import DisclaimerBlock from '../components/content/DisclaimerBlock.astro';
import resources from '../data/resources.json';

type Verification = 'confirmed' | 'needs-follow-up' | 'records-requested';

const lastUpdated = '04.25 / 2026';

// Group resources by category. Order categories per docs/CONTENT.md.
const categoryOrder = [
  'Start Here',
  'Energy',
  'Water',
  'Air Quality',
  'Noise',
  'Stormwater',
  'Health',
  'Tax & Incentives',
  'Local Coverage',
];
const grouped = categoryOrder
  .map((cat) => ({
    category: cat,
    items: resources.filter((r) => r.category === cat),
  }))
  .filter((g) => g.items.length > 0);

// "Why are residents concerned?" topic blocks. Body register, two to three
// short sentences each. The learn page intentionally separates a confirmed
// public-record register (used elsewhere on the site) from this educational
// register: nothing here asserts a specific impact at the K-Nova site.
const concerns = [
  {
    title: 'Electricity and grid demand.',
    body:
      'Large data centers can draw tens to hundreds of megawatts at a single site. Grid upgrades to serve them can affect long-run regional electricity costs and reliability for nearby ratepayers.',
  },
  {
    title: 'Water and cooling.',
    body:
      'Cooling design drives water use. Some designs use almost none on site. Others use significant volumes from public water systems and discharge warm water back into local sewers.',
  },
  {
    title: 'Backup generators and air quality.',
    body:
      'Most large data centers run diesel or natural-gas backup generators on site. They are tested regularly and can run for extended periods during grid disturbances. Generator emissions are regulated by federal and state air rules.',
  },
  {
    title: 'Noise and vibration.',
    body:
      'Mechanical cooling, transformers, and emergency generators run continuously. Sound levels at the nearest residence depend on equipment, screening, and distance, and are usually modeled as part of the site plan review.',
  },
  {
    title: 'Stormwater and construction runoff.',
    body:
      'A construction phase of this size brings months of grading, dust, and earth movement. Stormwater pollution prevention plans are required by federal and state rules.',
  },
  {
    title: 'Traffic and road impact.',
    body:
      'Construction traffic, truck routes, and long-term site access affect adjacent roads. Traffic and routing plans are usually part of the site plan record.',
  },
  {
    title: 'Land use near homes.',
    body:
      'Industrial-scale buildings adjacent to a residential neighborhood raise long-running questions about screening, lighting, sight lines, property value, and what the area will look like in ten years.',
  },
  {
    title: 'Tax incentives and long-term public costs.',
    body:
      'Data center projects are often supported by state or local tax incentives. Communities frequently weigh those incentives against long-term infrastructure, school, and service costs.',
  },
  {
    title: 'Transparency and NDAs.',
    body:
      'Some data-center deals involve non-disclosure agreements between developers, hyperscale tenants, and local governments. Residents often ask which parts of a deal are public, which are not, and why.',
  },
];
---

<SiteLayout
  title="Data center education hub | Foxfire Coalition"
  description="Learn about data centers, energy demand, water use, noise, air quality, stormwater, land use, and community impacts using credible public resources."
  lastUpdated={lastUpdated}
>
  <section class="page-section page-section-tier">
    <div class="measure">
      <SectionHeading kicker="Learn" title="Learn about data centers." />
      <p class="lede">
        This page is an education hub. It does not assert specific impacts at the K-Nova site.
        It explains the kinds of impacts a large data center campus can produce and links to
        credible national resources so residents can learn the vocabulary before reading the
        public record.
      </p>
    </div>
  </section>

  <section class="page-section">
    <div class="measure">
      <SectionHeading kicker="The basics" title="What is a data center?" />
      <p>
        A data center is a building, or group of buildings, full of computers running cloud and
        artificial-intelligence workloads. The largest ones can use as much electricity as a
        small city and significant amounts of water for cooling. They sit behind fences, run
        twenty-four hours a day, and rely on backup generators when the grid goes out.
      </p>
    </div>
  </section>

  <section class="page-section">
    <div class="measure">
      <SectionHeading kicker="Concerns" title="Why are residents concerned?" />
      <ul class="concerns-list">
        {concerns.map((c) => (
          <li>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Featured resources, grouped by category. Resources marked
       verification: records-requested render with a "Pending review"
       indicator until coalition review confirms. -->
  <section class="page-section">
    <div class="measure-wide">
      <SectionHeading kicker="Resources" title="Featured resources." />
      <p class="lede">
        Independent reports and government materials, grouped by topic. Use these to learn the
        vocabulary before reading the public record on the K-Nova site.
      </p>
      {grouped.map((group) => (
        <div class="resource-group">
          <h3 class="resource-group-title">{group.category}</h3>
          <div class="resource-grid">
            {group.items.map((r) => (
              <ResourceCard
                title={r.title}
                source_organization={r.source_organization}
                category={r.category}
                url={r.url}
                summary={r.summary}
                credibility_type={r.credibility_type}
                key_takeaway={r.key_takeaway}
                verification={r.verification as Verification}
              />
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <DisclaimerBlock includeFigures={true} />
</SiteLayout>
