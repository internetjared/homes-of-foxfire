---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeading from '../components/content/SectionHeading.astro';
import Icon from '../components/content/Icon.astro';
import questions from '../data/questions.json';

const lastUpdated = '04.30 / 2026';

const petitionUrl = 'https://www.change.org/p/prevent-the-construction-of-data-centers-in-commercial-point-and-scioto-township';
---

<SiteLayout
  title="Questions Residents Are Asking | Foxfire Coalition"
  description="Public records show that nearly 267 acres near Foxfire have been rezoned for data-center use. These are the questions residents are still asking about what happened, what remains, and what can still be done."
  lastUpdated={lastUpdated}
>

  <!-- Hero -->
  <section class="page-section page-section-tier">
    <div class="measure">
      <p class="kicker">Questions residents are asking</p>
      <h1 class="questions-title">267 acres rezoned. Still no answers.</h1>
      <p class="lede">
        The May 20, 2024 vote did not answer the questions residents are still asking.
        Water. Power. Noise. The emergency clause. The 48-hour resubmission. The missing
        studies. The vote did not answer any of these.
      </p>
    </div>
  </section>

  <!-- Q&A sections -->
  <section class="page-section questions-body">
    <div class="measure">
      {questions.map((cat) => (
        <div class="questions-category" id={cat.id}>
          <SectionHeading
            num={cat.num}
            title={cat.title}
            variant="ruled"
            id={`heading-${cat.id}`}
          />
          <ul class="faq-list">
            {cat.items.map((item, i) => (
              <li class="faq-item">
                <span class="faq-num mono tab">
                  {cat.num}.{String(i + 1).padStart(2, '0')}
                </span>
                <div>
                  <p class="faq-q">{item.question}</p>
                  <p class="faq-a" set:html={item.answer}></p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA pre-footer -->
  <section class="pre-footer pre-footer-questions" aria-label="Take action">
    <div class="pre-footer-inner">
      <p class="pre-footer-kicker">This is not over.</p>
      <h2 class="pre-footer-title">
        Read the record.<br />Ask the questions.<br />Show up.
      </h2>
      <p class="pre-footer-body">
        These questions do not answer themselves. The next decision about Foxfire is
        made in a room where residents can be present.
      </p>
      <p class="pre-footer-ctas">
        <a class="btn-primary" href="/take-action">Take action <Icon name="megaphone" size={14} /></a>
      </p>
    </div>
  </section>

</SiteLayout>

<style>
  .questions-title {
    font-size: clamp(2rem, 3.8vw, 3rem);
    line-height: 1.15;
    margin: 0 0 var(--space-md);
    max-width: 22ch;
  }

  .questions-body {
    padding-top: 0;
  }

  .questions-category {
    margin-bottom: var(--space-3xl);
  }

  .questions-category:last-child {
    margin-bottom: 0;
  }
</style>
