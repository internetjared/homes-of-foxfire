---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeading from '../components/content/SectionHeading.astro';
import Icon from '../components/content/Icon.astro';
import questions from '../data/questions.json';

const lastUpdated = '04.30 / 2026';

const petitionUrl = 'https://www.change.org/p/prevent-the-construction-of-data-centers-in-commercial-point-and-scioto-township';
---

<SiteLayout
  title="Questions Residents Are Asking | Foxfire Coalition"
  description="Public records show that nearly 267 acres near Foxfire have been rezoned for data-center use. These are the questions residents are still asking about what happened, what remains, and what can still be done."
  lastUpdated={lastUpdated}
>

  <!-- Split layout: sticky hero + scrolling Q&A -->
  <section class="questions-layout">
    <aside class="questions-layout-aside">
      <div class="questions-layout-aside-inner">
        <p class="kicker">Questions residents are asking</p>
        <h1 class="questions-title">267 acres rezoned.<br />Still no answers.</h1>
        <p class="lede">
          The May 20, 2024 vote did not answer the questions residents are still asking.
          Water. Power. Noise. Setbacks. Home values. The emergency clause. The 48-hour
          resubmission. Lack of studies and more.
        </p>
        <p class="questions-aside-cta">
          <a class="btn-primary" href="/take-action#council-emails">Ask council <Icon name="mail" size={14} /></a>
        </p>
      </div>
    </aside>

    <div class="questions-layout-body">
      {questions.map((cat) => (
        <div class="questions-category" id={cat.id}>
          <SectionHeading
            num={cat.num}
            title={cat.title}
            variant="ruled"
            id={`heading-${cat.id}`}
          />
          <ul class="faq-list">
            {cat.items.map((item, i) => (
              <li class="faq-item">
                <span class="faq-num mono tab">
                  {cat.num}.{String(i + 1).padStart(2, '0')}
                </span>
                <div>
                  <p class="faq-q">{item.question}</p>
                  <p class="faq-a" set:html={item.answer}></p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA pre-footer -->
  <section class="pre-footer pre-footer-questions" aria-label="Take action">
    <div class="pre-footer-inner">
      <p class="pre-footer-kicker">This is not over.</p>
      <h2 class="pre-footer-title">
        Read the record.<br />Ask the questions.<br />Show up.
      </h2>
      <p class="pre-footer-body">
        These questions do not answer themselves. The next decision about Foxfire is
        made in a room where residents can be present.
      </p>
      <p class="pre-footer-ctas">
        <a class="btn-primary" href="/take-action">Take action <Icon name="megaphone" size={14} /></a>
      </p>
    </div>
  </section>

</SiteLayout>

<style>
  .questions-title {
    font-size: clamp(2.25rem, 3.6vw, 3.25rem);
    line-height: 1.05;
    margin: 0 0 var(--space-md);
    max-width: 16ch;
    letter-spacing: -0.01em;
  }

  /* In the split layout, lighten and tighten the per-category headings. */
  .questions-layout-body :global(.section-heading-ruled) {
    border-top: none;
    padding-top: 0;
  }

  .questions-layout-body :global(.section-heading h2) {
    font-size: clamp(1.375rem, 2vw, 1.75rem);
    line-height: 1.2;
  }

  .questions-layout-body :global(.faq-list) {
    border-top-color: var(--rule-soft);
  }

  .questions-layout {
    display: grid;
    grid-template-columns: minmax(380px, 480px) 1fr;
    gap: var(--space-2xl);
    max-width: var(--frame);
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) var(--space-4xl);
    align-items: start;
  }

  .questions-layout-aside {
    align-self: start;
    position: sticky;
    /* sticky `top` matches the rail's natural position — status bar + header
       + the layout's own top padding — so the rail is sticky from frame 1
       and never travels even one pixel. */
    top: calc(var(--sticky-bar-h, 52px) + var(--header-h, 114px) + var(--space-2xl));
  }

  .questions-layout-aside-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .questions-layout-aside .lede {
    font-size: 17px;
    line-height: 1.5;
    margin: 0;
    max-width: 32ch;
  }

  .questions-aside-cta {
    margin: var(--space-md) 0 0;
  }

  .questions-layout-body {
    min-width: 0;
  }

  .questions-category {
    margin-bottom: var(--space-3xl);
  }

  .questions-category:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .questions-layout {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
      padding: var(--space-2xl) var(--space-lg) var(--space-3xl);
    }
    .questions-layout-aside {
      position: static;
    }
    .questions-title {
      font-size: clamp(2rem, 3.8vw, 3rem);
      max-width: 22ch;
    }
  }
</style>
