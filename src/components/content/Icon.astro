---
/* Icon.astro
 *
 * Small inline-SVG solid-icon set. Civic, editorial, no dependencies.
 * Icons inherit currentColor and are sized via the `size` prop (px).
 *
 * Decorative by default (aria-hidden). Pass an `ariaLabel` to expose
 * the icon to assistive tech as an image with that label.
 */

type IconName =
  | 'mail'
  | 'pen'
  | 'heart'
  | 'calendar'
  | 'map-pin'
  | 'clock'
  | 'microphone'
  | 'arrow-right'
  | 'file-text'
  | 'gavel'
  | 'check'
  | 'megaphone'
  | 'thumbs-up'
  | 'copy';

interface Props {
  name: IconName;
  size?: number;
  class?: string;
  ariaLabel?: string;
}

const { name, size = 18, class: className, ariaLabel } = Astro.props;

const a11y = ariaLabel
  ? { role: 'img', 'aria-label': ariaLabel }
  : { 'aria-hidden': 'true', focusable: 'false' };
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="currentColor"
  class:list={['icon', className]}
  data-icon={name}
  {...a11y}
>
  {name === 'mail' && (
    <path d="M2 6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v.5l-10 6.2L2 6.5Zm0 2.85V18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8.85l-10 6.2-10-6.2Z" />
  )}
  {name === 'pen' && (
    <path d="M16.7 3.3a2.4 2.4 0 0 1 3.4 0l.6.6a2.4 2.4 0 0 1 0 3.4l-2 2-4-4 2-2ZM13.3 6.7l4 4L7 21l-5 1 1-5L13.3 6.7Z" />
  )}
  {name === 'heart' && (
    <path d="M12 21s-7-4.6-9.3-9.4C1.2 8.3 3.2 4 7 4c2.1 0 3.7 1.1 5 2.6C13.3 5.1 14.9 4 17 4c3.8 0 5.8 4.3 4.3 7.6C19 16.4 12 21 12 21Z" />
  )}
  {name === 'calendar' && (
    <>
      <path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h2a2 2 0 0 1 2 2v3H2V6a2 2 0 0 1 2-2h2V3a1 1 0 0 1 1-1Z" />
      <path d="M22 11v9a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-9h20Zm-15 3v3h3v-3H7Zm5 0v3h3v-3h-3Z" />
    </>
  )}
  {name === 'map-pin' && (
    <path d="M12 2a8 8 0 0 0-8 8c0 5.5 8 12 8 12s8-6.5 8-12a8 8 0 0 0-8-8Zm0 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z" />
  )}
  {name === 'clock' && (
    <path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm1 10.4V6a1 1 0 1 0-2 0v7l4.5 2.5.9-1.7L13 12.4Z" />
  )}
  {name === 'microphone' && (
    <>
      <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z" />
      <path d="M5 11a1 1 0 0 1 2 0 5 5 0 0 0 10 0 1 1 0 1 1 2 0 7 7 0 0 1-6 6.93V21h3a1 1 0 1 1 0 2H8a1 1 0 1 1 0-2h3v-3.07A7 7 0 0 1 5 11Z" />
    </>
  )}
  {name === 'arrow-right' && (
    <path d="M13.3 5.3a1 1 0 0 1 1.4 0l6 6a1 1 0 0 1 0 1.4l-6 6a1 1 0 1 1-1.4-1.4L17.6 13H4a1 1 0 1 1 0-2h13.6l-4.3-4.3a1 1 0 0 1 0-1.4Z" />
  )}
  {name === 'file-text' && (
    <path d="M5 2a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.4L14.6 2H5Zm9 1.5L19.5 9H15a1 1 0 0 1-1-1V3.5ZM7 12h10v2H7v-2Zm0 4h10v2H7v-2Zm0-8h5v2H7V8Z" />
  )}
  {name === 'gavel' && (
    <path d="M14.5 2.5 21.5 9.5l-2.1 2.1-7-7L14.5 2.5ZM10.4 6.6 17.4 13.6 13.6 17.4 6.6 10.4 10.4 6.6ZM4.5 14.5 9.5 19.5 7.4 21.6a1.5 1.5 0 0 1-2.1 0l-2.9-2.9a1.5 1.5 0 0 1 0-2.1l2.1-2.1Z" />
  )}
  {name === 'check' && (
    <path d="M20.3 6.3a1 1 0 0 1 0 1.4l-10 10a1 1 0 0 1-1.4 0l-5-5a1 1 0 0 1 1.4-1.4l4.3 4.3 9.3-9.3a1 1 0 0 1 1.4 0Z" />
  )}
  {name === 'megaphone' && (
    <path d="M3 9.5C3 8.7 3.7 8 4.5 8H8l8-5v18l-8-5H6v3a1.5 1.5 0 0 1-3 0V14.5a3 3 0 0 1 0-5Zm15-1.4v7.8c1.7-.5 3-2.1 3-3.9s-1.3-3.4-3-3.9Z" />
  )}
  {name === 'thumbs-up' && (
    <path d="M2 20h2a1 1 0 0 0 1-1v-8a1 1 0 0 0-1-1H2v10Zm18.7-9.3A2 2 0 0 0 19 10h-5V6a3 3 0 0 0-3-3h-1v2c0 2.1-.8 4-2.3 5.4L7 12v7h10.3l2.5-6.3a2 2 0 0 0-.1-2Z" />
  )}
  {name === 'copy' && (
    <path d="M16 1H4a2 2 0 0 0-2 2v14h2V3h12V1Zm3 4H8a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2Zm0 16H8V7h11v14Z" />
  )}
</svg>

<style>
  .icon {
    display: inline-block;
    flex-shrink: 0;
    vertical-align: middle;
  }
</style>
