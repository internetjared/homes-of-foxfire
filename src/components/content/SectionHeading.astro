---
interface Props {
  kicker?: string;
  title: string;
  num?: string;
  variant?: 'default' | 'ruled';
  id?: string;
}

const { kicker, title, num, variant = 'default', id } = Astro.props;

const classes = [
  'section-heading',
  variant === 'ruled' && 'section-heading-ruled',
  num && 'section-heading-numbered',
].filter(Boolean).join(' ');
---

<header class={classes}>
  {num && <span class="section-heading-num mono" aria-hidden="true">{num}</span>}
  <div class="section-heading-text">
    {kicker && <p class="kicker">{kicker}</p>}
    <h2 id={id}>{title}</h2>
  </div>
</header>
