---
/* DisclaimerBlock
 *
 * Single source of truth for the legal-procedural disclaimer specified
 * in docs/SOURCES.md. Renders on every public page that touches legal
 * or procedural matters. Optional companion line for pages that touch
 * health, environmental, or utility figures (per the same spec).
 *
 * If the disclaimer wording ever changes, change it here. Do not retype.
 */

interface Props {
  /**
   * When true, render the health/environmental/utility companion line
   * after the legal disclaimer. Use on /learn and any other page that
   * cites or describes those kinds of impacts.
   */
  includeFigures?: boolean;
}

const { includeFigures = false } = Astro.props;
---

<section class="page-section">
  <div class="measure">
    <div class="disclaimer">
      <p>
        The Homes of Foxfire Coalition is a volunteer neighborhood organization. Nothing on this
        site is legal advice. Residents who believe they have a legal interest in any matter
        described here should consult a licensed attorney.
      </p>
      {includeFigures && (
        <p>
          Health, environmental, and utility figures cited here come from public sources. They
          are illustrative of the kinds of impacts large data center facilities can produce and
          are not a prediction about the specific facilities under discussion. Facility-specific
          impacts depend on facility-specific design, which is not yet on the public record.
        </p>
      )}
    </div>
  </div>
</section>
