---
import Wordmark from '../brand/Wordmark.astro';
import Icon from '../content/Icon.astro';

// Site nav. Plain text links, then two CTA buttons at the end.
// "Donate" is an external link to GoFundMe (opens in new tab).
type NavItem = { href: string; label: string; external?: boolean; cta?: 'solid' | 'outlined' };
const nav: NavItem[] = [
  { href: '/', label: 'Home' },
  { href: '/timeline', label: 'Timeline' },
  { href: '/updates', label: 'Updates' },
  { href: '/take-action', label: 'Take action', cta: 'solid' },
  { href: 'https://www.gofundme.com/f/support-community-action-against-data-center', label: 'Donate', external: true, cta: 'outlined' },
];

const ctaItems = nav.filter(i => i.cta);
const linkItems = nav.filter(i => !i.cta);

// Highlight the current route.
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="site-header-inner">
    <Wordmark variant="stacked" href="/" />

    <!-- Desktop nav -->
    <nav class="site-header-nav site-header-nav-desktop" aria-label="Primary">
      {nav.map((item) => {
        const ctaClass = item.cta === 'solid'
          ? 'site-header-cta site-header-cta-solid'
          : item.cta === 'outlined'
            ? 'site-header-cta site-header-cta-outlined'
            : undefined;

        if (item.external) {
          return (
            <a href={item.href} target="_blank" rel="noopener" class={ctaClass}>
              {item.label === 'Donate' && <Icon name="heart" size={13} />}
              {item.label}
            </a>
          );
        }
        const itemPath = item.href.replace(/\/$/, '') || '/';
        const isCurrent = itemPath === path;
        return (
          <a href={item.href} aria-current={isCurrent ? 'page' : undefined} class={ctaClass}>
            {item.label === 'Take action' && <Icon name="megaphone" size={13} />}
            {item.label}
          </a>
        );
      })}
    </nav>

    <!-- Mobile: hamburger only (same row as wordmark) -->
    <button
      class="site-header-hamburger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span class="site-header-hamburger-bar"></span>
      <span class="site-header-hamburger-bar"></span>
      <span class="site-header-hamburger-bar"></span>
    </button>
  </div>

  <!-- Mobile: CTA bar below header -->
  <div class="site-header-cta-bar">
    {ctaItems.map((item) => {
      const ctaClass = item.cta === 'solid'
        ? 'site-header-cta site-header-cta-solid'
        : 'site-header-cta site-header-cta-outlined';
      return item.external
        ? (
          <a href={item.href} target="_blank" rel="noopener" class={ctaClass}>
            <Icon name="heart" size={13} />{item.label}
          </a>
        )
        : (
          <a href={item.href} class={ctaClass}>
            <Icon name="megaphone" size={13} />{item.label}
          </a>
        );
    })}
  </div>

  <!-- Mobile nav drawer -->
  <nav id="mobile-nav" class="site-header-nav-mobile" aria-label="Primary">
    {linkItems.map((item) => {
      const itemPath = item.href.replace(/\/$/, '') || '/';
      const isCurrent = itemPath === path;
      return (
        <a href={item.href} aria-current={isCurrent ? 'page' : undefined}>
          {item.label}
        </a>
      );
    })}
  </nav>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.querySelector<HTMLButtonElement>('.site-header-hamburger');
    const nav = document.getElementById('mobile-nav');
    if (!btn || !nav) return;

    btn.addEventListener('click', () => {
      const isOpen = btn.classList.contains('is-open');
      btn.classList.toggle('is-open', !isOpen);
      nav.classList.toggle('is-open', !isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
      btn.setAttribute('aria-label', isOpen ? 'Open navigation menu' : 'Close navigation menu');
    });
  });
</script>
