---
import Icon from '../content/Icon.astro';

// Site nav. Plain text links, then two CTA buttons at the end.
// "Donate" is an external link to GoFundMe (opens in new tab).
type NavItem = { href: string; label: string; external?: boolean; cta?: 'solid' | 'outlined' };
const nav: NavItem[] = [
  { href: '/', label: 'Home' },
  { href: '/questions', label: 'Questions' },
  { href: '/timeline', label: 'Timeline' },
  { href: '/updates', label: 'Updates' },
  { href: '/take-action', label: 'Take action', cta: 'solid' },
  { href: 'https://www.gofundme.com/f/support-community-action-against-data-center', label: 'Donate', external: true, cta: 'outlined' },
];

const ctaItems = nav.filter(i => i.cta);
const linkItems = nav.filter(i => !i.cta);

// Highlight the current route.
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="site-header-logo" aria-label="Foxfire Coalition — home">
      <img src="/logo.png" alt="Foxfire Coalition" width="180" height="56" />
    </a>

    <!-- Desktop nav: centered plain links -->
    <nav class="site-header-nav site-header-nav-desktop site-header-nav-center" aria-label="Primary">
      {linkItems.map((item) => {
        const itemPath = item.href.replace(/\/$/, '') || '/';
        const isCurrent = itemPath === path;
        return (
          <a href={item.href} aria-current={isCurrent ? 'page' : undefined}>
            {item.label}
          </a>
        );
      })}
    </nav>

    <!-- Desktop nav: right-aligned CTAs -->
    <nav class="site-header-nav site-header-nav-desktop site-header-nav-end" aria-label="Primary actions">
      <a
        class="site-header-social"
        href="https://www.facebook.com/profile.php?id=61588876811225"
        target="_blank"
        rel="noopener"
        aria-label="Follow Foxfire Coalition on Facebook"
      >
        <span>Follow</span>
        <Icon name="facebook" size={16} />
      </a>
      {ctaItems.map((item) => {
        const ctaClass = item.cta === 'solid'
          ? 'site-header-cta site-header-cta-solid'
          : 'site-header-cta site-header-cta-outlined';

        if (item.external) {
          return (
            <a href={item.href} target="_blank" rel="noopener" class={ctaClass}>
              {item.label}
              {item.label === 'Donate' && <Icon name="heart" size={13} />}
            </a>
          );
        }
        const itemPath = item.href.replace(/\/$/, '') || '/';
        const isCurrent = itemPath === path;
        return (
          <a href={item.href} aria-current={isCurrent ? 'page' : undefined} class={ctaClass}>
            {item.label}
            {item.label === 'Take action' && <Icon name="megaphone" size={13} />}
          </a>
        );
      })}
    </nav>

    <!-- Mobile: hamburger only (same row as wordmark) -->
    <button
      class="site-header-hamburger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span class="site-header-hamburger-bar"></span>
      <span class="site-header-hamburger-bar"></span>
      <span class="site-header-hamburger-bar"></span>
    </button>
  </div>

  <!-- Mobile: CTA bar below header -->
  <div class="site-header-cta-bar">
    {ctaItems.map((item) => {
      const ctaClass = item.cta === 'solid'
        ? 'site-header-cta site-header-cta-solid'
        : 'site-header-cta site-header-cta-outlined';
      return item.external
        ? (
          <a href={item.href} target="_blank" rel="noopener" class={ctaClass}>
            {item.label}<Icon name="heart" size={13} />
          </a>
        )
        : (
          <a href={item.href} class={ctaClass}>
            {item.label}<Icon name="megaphone" size={13} />
          </a>
        );
    })}
    <a
      class="site-header-social"
      href="https://www.facebook.com/profile.php?id=61588876811225"
      target="_blank"
      rel="noopener"
      aria-label="Follow Foxfire Coalition on Facebook"
    >
      <span>Follow</span>
      <Icon name="facebook" size={16} />
    </a>
  </div>

  <!-- Mobile nav drawer -->
  <nav id="mobile-nav" class="site-header-nav-mobile" aria-label="Primary">
    {linkItems.map((item) => {
      const itemPath = item.href.replace(/\/$/, '') || '/';
      const isCurrent = itemPath === path;
      return (
        <a href={item.href} aria-current={isCurrent ? 'page' : undefined}>
          {item.label}
        </a>
      );
    })}
  </nav>
</header>

<script>
  // Mobile hamburger wiring.
  //
  // Uses `astro:page-load` (fires on initial load AND after every View Transition)
  // instead of `DOMContentLoaded` (fires only once, before Astro may have finished
  // hydrating). Idempotent via a data attribute so re-running across navigations
  // never double-binds the click listener.
  function wireHamburger() {
    const btn = document.querySelector<HTMLButtonElement>('.site-header-hamburger');
    const nav = document.getElementById('mobile-nav');
    if (!btn || !nav) return;

    // Skip if this exact button instance is already wired.
    if (btn.dataset.wired === 'true') return;
    btn.dataset.wired = 'true';

    const setOpen = (open: boolean) => {
      btn.classList.toggle('is-open', open);
      nav.classList.toggle('is-open', open);
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
    };

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      setOpen(!btn.classList.contains('is-open'));
    });

    // Close on Escape.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.classList.contains('is-open')) {
        setOpen(false);
        btn.focus();
      }
    });

    // Close when clicking/tapping outside the menu (but not the button itself).
    document.addEventListener('click', (e) => {
      if (!btn.classList.contains('is-open')) return;
      const target = e.target as Node | null;
      if (!target) return;
      if (nav.contains(target) || btn.contains(target)) return;
      setOpen(false);
    });

    // Close after following an in-page link inside the drawer.
    nav.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });
  }

  // Fire on first load and on every Astro page transition.
  document.addEventListener('astro:page-load', wireHamburger);

  // Belt-and-suspenders: also run if the script lands while the document is already
  // interactive (covers edge cases where astro:page-load has already fired).
  if (document.readyState !== 'loading') {
    wireHamburger();
  } else {
    document.addEventListener('DOMContentLoaded', wireHamburger);
  }
</script>
