    <a href="/" class="site-footer-logo" aria-label="Foxfire Coalition — home">
      <img src="/logo.png" alt="Foxfire Coalition" width="140" height="44" />
    </a>

    <nav class="site-footer-nav" aria-label="Site sections">
      <a href="/">Home</a>
      <a href="/questions">Questions</a>
