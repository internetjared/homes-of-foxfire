---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import StickyStatusBar from '../components/site/StickyStatusBar.astro';
import '../styles/components.css';

import type { ArticleMeta } from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
  requestId?: string;
  // SEO passthroughs to BaseLayout
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  type?: 'website' | 'article';
  articleMeta?: ArticleMeta;
  extraSchema?: object;
  noindex?: boolean;
}

const {
  title,
  description,
  lastUpdated,
  requestId,
  image,
  imageWidth,
  imageHeight,
  type,
  articleMeta,
  extraSchema,
  noindex,
} = Astro.props;

// Procedural status surfaces. Read at the layout level so every public
// route shows the same as-of stamp and next-meeting indicator without
// per-page boilerplate.
//
// Sticky status bar is currently suppressed site-wide (no agenda yet for
// the next meeting). Per-page meeting cards still render from the same
// meetings.json data.
const asOf = lastUpdated;
const nextMeeting = null;
const nextMeetingDate = null;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageWidth={imageWidth}
  imageHeight={imageHeight}
  type={type}
  articleMeta={articleMeta}
  extraSchema={extraSchema}
  noindex={noindex}
>
  <a class="skip-link" href="#main">Skip to main content.</a>
  <StickyStatusBar
    meeting={nextMeeting}
    meetingDate={nextMeetingDate}
    asOf={asOf}
  />
  <SiteHeader />
  <main id="main">
    <slot />
  </main>
  <SiteFooter />
</BaseLayout>

<script>
  // ---------------------------------------------------------------------------
  // Sticky layout vars — keep --sticky-bar-h and --header-h accurate at all
  // times so the header sits flush under the status bar and the Take Action
  // step numbers stick just below the header.
  //
  // ResizeObserver fires whenever either element changes size (wrap reflow on
  // mobile, compact transition on scroll, font-load reflow, etc.).
  // ---------------------------------------------------------------------------
  let _stickyRO: ResizeObserver | null = null;

  function initStickyVars() {
    _stickyRO?.disconnect();

    const bar    = document.querySelector<HTMLElement>('.sticky-status');
    const header = document.querySelector<HTMLElement>('.site-header');
    const root   = document.documentElement;

    const update = () => {
      if (bar)    root.style.setProperty('--sticky-bar-h', bar.offsetHeight  + 'px');
      if (header) root.style.setProperty('--header-h',     header.offsetHeight + 'px');
    };

    _stickyRO = new ResizeObserver(update);
    if (bar)    _stickyRO.observe(bar);
    if (header) _stickyRO.observe(header);
    update(); // set immediately so first paint is correct
  }

  // ---------------------------------------------------------------------------
  // Compact header: two-way scroll shrink that persists across View Transitions.
  // ---------------------------------------------------------------------------
  let _headerScrollCleanup: (() => void) | null = null;

  function initCompactHeader() {
    _headerScrollCleanup?.();
    _headerScrollCleanup = null;

    const header = document.querySelector<HTMLElement>('.site-header');
    if (!header) return;

    const THRESHOLD = 60;
    const onScroll = () => {
      header.classList.toggle('is-compact', window.scrollY > THRESHOLD);
    };

    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    _headerScrollCleanup = () => window.removeEventListener('scroll', onScroll);
  }

  // Both inits run on first load and after every View Transition
  document.addEventListener('astro:page-load', () => {
    initStickyVars();
    initCompactHeader();
  });

  // Apply compact state immediately after DOM swap so the header is the right
  // size before the fade-in animation plays
  document.addEventListener('astro:after-swap', () => {
    const header = document.querySelector<HTMLElement>('.site-header');
    if (header) header.classList.toggle('is-compact', window.scrollY > 60);
  });

  // Reveal: stagger timeline rows into view (motion-safe; CSS hides the
  // animation under prefers-reduced-motion via @media query in components.css).
  (function () {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return;

    const containers = document.querySelectorAll<HTMLElement>('[data-reveal="timeline"]');
    containers.forEach((container) => {
      const rows = Array.from(container.querySelectorAll<HTMLElement>('.timeline-row'));
      if (!rows.length) return;

      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const idx = rows.indexOf(entry.target as HTMLElement);
              const el = entry.target as HTMLElement;
              el.style.transitionDelay = `${Math.max(0, idx) * 80}ms`;
              el.classList.add('is-visible');
              obs.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
      );

      rows.forEach((row) => obs.observe(row));
    });
  })();

  // aria-current="location" on the OnThisPage index when the matching
  // section enters the viewport. Works for any anchor list under .on-this-page-list.
  (function () {
    const lists = document.querySelectorAll<HTMLElement>('.on-this-page-list');
    if (!lists.length) return;

    const linkMap = new Map<string, HTMLAnchorElement>();
    lists.forEach((list) => {
      list.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
        const id = a.getAttribute('href')!.slice(1);
        if (id) linkMap.set(id, a);
      });
    });

    if (!linkMap.size) return;

    const targets: HTMLElement[] = [];
    linkMap.forEach((_link, id) => {
      const el = document.getElementById(id);
      if (el) targets.push(el);
    });

    if (!targets.length) return;

    const visible = new Set<string>();

    const setCurrent = () => {
      // Pick the topmost visible target.
      let topId: string | null = null;
      let topY = Infinity;
      visible.forEach((id) => {
        const el = document.getElementById(id);
        if (!el) return;
        const y = el.getBoundingClientRect().top;
        if (y < topY) {
          topY = y;
          topId = id;
        }
      });

      linkMap.forEach((link, id) => {
        if (id === topId) {
          link.setAttribute('aria-current', 'location');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = (entry.target as HTMLElement).id;
          if (entry.isIntersecting) visible.add(id);
          else visible.delete(id);
        });
        setCurrent();
      },
      { rootMargin: '-30% 0px -60% 0px', threshold: 0 }
    );

    targets.forEach((t) => obs.observe(t));
  })();

  // Parallax: drives both .hero::before and .pre-footer::before via CSS variables.
  // Disabled under prefers-reduced-motion.
  (function () {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return;

    const hero = document.querySelector<HTMLElement>('.hero');
    const preFooter = document.querySelector<HTMLElement>('.pre-footer');

    const HERO_SPEED = 0.05;
    const PREFOOTER_SPEED = 0.05;
    const MAX_PX = 120;

    const parallaxEl = (el: HTMLElement, varName: string, speed: number) => {
      const rect = el.getBoundingClientRect();
      const center = rect.top + rect.height / 2 - window.innerHeight / 2;
      const offset = Math.max(-MAX_PX, Math.min(MAX_PX, center * speed));
      el.style.setProperty(varName, `${offset}px`);
    };

    let ticking = false;

    const update = () => {
      if (hero) parallaxEl(hero, '--hero-parallax', HERO_SPEED);
      if (preFooter) parallaxEl(preFooter, '--prefooter-parallax', PREFOOTER_SPEED);
      ticking = false;
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
  })();
</script>
