---
import { ViewTransitions } from 'astro:transitions';
import '../styles/tokens.css';
import '../styles/base.css';

export interface ArticleMeta {
  publishedTime: string;          // ISO 8601
  modifiedTime?: string;          // ISO 8601
  section?: string;               // category label
  authorName?: string;            // person/organization name
}

interface Props {
  title: string;
  description?: string;
  image?: string;                 // absolute URL or path under /; overrides default OG image
  type?: 'website' | 'article';   // og:type; default 'website'
  articleMeta?: ArticleMeta;      // article-specific OG/meta when type='article'
  extraSchema?: object;           // page-specific JSON-LD object to emit alongside Org/WebPage
  noindex?: boolean;              // emit `noindex,nofollow` for this page
}

const {
  title,
  description = 'Homes of Foxfire Coalition',
  image,
  type = 'website',
  articleMeta,
  extraSchema,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://foxfirecoalition.org';

// Resolve OG image: per-page override (relative or absolute) or site-wide default.
const defaultOgImage = `${siteUrl}/FCADC_Social.jpg`;
const resolvedOgImage = image
  ? (image.startsWith('http') ? image : `${siteUrl}${image.startsWith('/') ? '' : '/'}${image}`)
  : defaultOgImage;

const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();

// Organization JSON-LD — site-wide, appears on every page
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}#organization`,
  name: 'Homes of Foxfire Coalition Against Data Centers',
  alternateName: 'Foxfire Coalition',
  url: siteUrl,
  logo: `${siteUrl}/favicon.png`,
  description:
    'A resident-led coalition in Commercial Point, Pickaway County, Ohio, organizing against a 267-acre data center development next to the Foxfire neighborhood.',
  areaServed: {
    '@type': 'Place',
    name: 'Commercial Point, Pickaway County, Ohio',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'info@foxfirecoalition.org',
    contactType: 'community organizing',
  },
};

// WebPage JSON-LD — scoped to this specific page
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: canonicalUrl,
  isPartOf: { '@id': siteUrl },
  inLanguage: 'en-US',
  primaryImageOfPage: resolvedOgImage,
};
---
<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1A2742" />
    <meta name="author" content="Homes of Foxfire Coalition" />
    <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large'} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OpenGraph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:type" content={resolvedOgImage.endsWith('.png') ? 'image/png' : 'image/jpeg'} />
    <meta property="og:image:alt" content="Foxfire Coalition Against Data Centers" />
    {!image && <meta property="og:image:width" content="1445" />}
    {!image && <meta property="og:image:height" content="854" />}
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Foxfire Coalition Against Data Centers" />

    {/* Article-specific OG when this page is a blog post */}
    {type === 'article' && articleMeta && (
      <>
        <meta property="article:published_time" content={articleMeta.publishedTime} />
        {articleMeta.modifiedTime && <meta property="article:modified_time" content={articleMeta.modifiedTime} />}
        {articleMeta.section && <meta property="article:section" content={articleMeta.section} />}
        {articleMeta.authorName && <meta property="article:author" content={articleMeta.authorName} />}
      </>
    )}

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:image:alt" content="Foxfire Coalition Against Data Centers" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    {extraSchema && <script type="application/ld+json" set:html={JSON.stringify(extraSchema)} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@400;500;600&family=Public+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
    />
    <ViewTransitions />

    <!-- Google Analytics GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9KJK4C9SN3"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9KJK4C9SN3');

      // Re-fire pageview on Astro View Transitions navigations
      document.addEventListener('astro:page-load', () => {
        gtag('event', 'page_view', {
          page_location: window.location.href,
          page_title: document.title,
        });
      });
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
