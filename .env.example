# Foxfire Coalition website environment variables
#
# Copy this file to .env (which is gitignored) and fill in the real values.
# In production, set the same variables on Vercel under Project Settings → Environment Variables.

# --- Sanity CMS ---
# Project ID from https://www.sanity.io/manage (e.g., a8b9c1d2)
PUBLIC_SANITY_PROJECT_ID=

# Dataset name. Default is "production" unless you created another one.
PUBLIC_SANITY_DATASET=production

# Sanity API version (date-pinned for stable behavior)
PUBLIC_SANITY_API_VERSION=2024-10-01

# Read token (only needed if dataset is private; public datasets do not need a token).
# Generate at https://www.sanity.io/manage → API → Tokens. Scope: Viewer.
SANITY_READ_TOKEN=

# --- Airtable ---
# Personal Access Token from https://airtable.com/create/tokens
# Required scopes: data.records:read on the Foxfire Coalition Research Database base
AIRTABLE_PAT=

# Airtable base ID. Starts with "app...". Find at https://airtable.com/<your-base-id>/api or in the Airtable URL.
AIRTABLE_BASE_ID=

# Optional: override the names of the Airtable tables the sync script reads from.
# Leave blank to use defaults: "Timeline Events" and "Documents".
AIRTABLE_TIMELINE_TABLE=Timeline Events
AIRTABLE_DOCUMENTS_TABLE=Documents
